---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import SmoothScroll from '../components/SmoothScroll.astro';
import '../styles/global.css';

type Props = CollectionEntry<'guides'>['data'];

const { title, description, pubDate, updatedDate, heroImage, category } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={`${title} — Indo Yachts`} description={description} />
	</head>

	<body>
		<Header />
		<main>
			<article>
				<!-- Hero Image -->
				{
					heroImage && (
						<div class="hero-image">
							<Image width={1400} height={700} src={heroImage} alt={title} />
						</div>
					)
				}

				<!-- Article Header -->
				<header class="article-header">
					<span class="article-category">{category}</span>
					<h1 class="article-title">{title}</h1>
					<div class="article-meta">
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<span class="updated">
									&mdash; Updated <FormattedDate date={updatedDate} />
								</span>
							)
						}
					</div>
					<div class="gold-divider"></div>
				</header>

				<!-- Article Body -->
				<div class="article-prose">
					<slot />
				</div>
			</article>

			<!-- CTA Banner -->
			<section class="cta-banner">
				<div class="cta-inner">
					<span class="cta-eyebrow">YOUR EXPEDITION AWAITS</span>
					<h2 class="cta-headline">Inspired to explore?</h2>
					<p class="cta-body">
						Let our charter specialists craft a bespoke itinerary tailored to your
						group, your interests, and the perfect season.
					</p>
					<a href="#contact" class="cta-button">
						Start Planning
						<span class="cta-arrow">&rarr;</span>
					</a>
				</div>
			</section>
		</main>
		<Footer />

		<style>
			/* ===== Reset for Guide Layout ===== */
			main {
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding: 0;
			}

			/* ===== Hero Image ===== */
			.hero-image {
				width: 100%;
				max-height: 560px;
				overflow: hidden;
			}
			.hero-image img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
				border-radius: 0;
			}

			/* ===== Article Header ===== */
			.article-header {
				max-width: 720px;
				margin: 0 auto;
				padding: var(--space-xl) var(--space-md) 0;
				text-align: center;
			}
			.article-category {
				display: inline-block;
				font-family: var(--font-sans);
				font-size: var(--text-sm);
				font-weight: 600;
				letter-spacing: 0.2em;
				text-transform: uppercase;
				color: var(--oxblood);
				margin-bottom: var(--space-sm);
			}
			.article-title {
				font-family: var(--font-serif);
				font-weight: 300;
				font-size: 42px;
				line-height: 1.1;
				color: var(--charcoal);
				margin: 0 0 var(--space-sm) 0;
			}
			.article-meta {
				font-family: var(--font-sans);
				font-size: var(--text-base);
				font-weight: 400;
				color: var(--silver);
				margin-bottom: var(--space-md);
			}
			.article-meta .updated {
				color: var(--pewter);
				font-style: italic;
			}
			.gold-divider {
				width: 64px;
				height: 1px;
				background-color: var(--gold-muted);
				margin: 0 auto;
			}

			/* ===== Article Prose ===== */
			.article-prose {
				max-width: 720px;
				margin: 0 auto;
				padding: var(--space-lg) var(--space-md) var(--space-xl);
				font-family: var(--font-sans);
				font-weight: 400;
				font-size: var(--text-md);
				line-height: 1.8;
				color: var(--slate);
			}
			.article-prose :global(h2) {
				font-family: var(--font-serif);
				font-weight: 300;
				font-size: var(--text-2xl);
				line-height: 1.15;
				color: var(--charcoal);
				margin: var(--space-lg) 0 var(--space-sm) 0;
			}
			.article-prose :global(h3) {
				font-family: var(--font-serif);
				font-weight: 400;
				font-size: var(--text-xl);
				line-height: 1.2;
				color: var(--charcoal);
				margin: var(--space-md) 0 var(--space-xs) 0;
			}
			.article-prose :global(p) {
				margin-bottom: 1.5em;
			}
			.article-prose :global(strong) {
				font-weight: 600;
				color: var(--charcoal);
			}
			.article-prose :global(a) {
				color: var(--oxblood);
				text-decoration: underline;
				text-decoration-color: rgba(149, 51, 52, 0.3);
				text-underline-offset: 3px;
				transition: text-decoration-color 0.3s ease;
			}
			.article-prose :global(a:hover) {
				text-decoration-color: var(--oxblood);
			}
			.article-prose :global(ul),
			.article-prose :global(ol) {
				padding-left: 1.5em;
				margin-bottom: 1.5em;
			}
			.article-prose :global(li) {
				margin-bottom: 0.5em;
				line-height: 1.75;
			}
			.article-prose :global(blockquote) {
				border-left: 3px solid var(--gold-muted);
				padding-left: var(--space-md);
				margin: var(--space-md) 0;
				font-family: var(--font-serif);
				font-style: italic;
				font-size: var(--text-xl);
				line-height: 1.5;
				color: var(--pewter);
			}
			.article-prose :global(hr) {
				border: none;
				border-top: 1px solid var(--mist);
				margin: var(--space-lg) 0;
			}
			.article-prose :global(img) {
				border-radius: 0;
			}

			/* ===== CTA Banner ===== */
			.cta-banner {
				background-color: var(--deep-sea);
				padding: var(--space-xl) var(--space-md);
				text-align: center;
			}
			.cta-inner {
				max-width: 620px;
				margin: 0 auto;
			}
			.cta-eyebrow {
				display: inline-block;
				font-family: var(--font-sans);
				font-size: var(--text-xs);
				font-weight: 600;
				letter-spacing: 0.2em;
				text-transform: uppercase;
				color: var(--gold-muted);
				margin-bottom: var(--space-sm);
			}
			.cta-headline {
				font-family: var(--font-serif);
				font-weight: 300;
				font-size: var(--text-3xl);
				line-height: 1.1;
				color: var(--iy-white);
				margin: 0 0 var(--space-sm) 0;
			}
			.cta-body {
				font-family: var(--font-sans);
				font-weight: 400;
				font-size: 15px;
				line-height: 1.75;
				color: rgba(255, 255, 255, 0.7);
				margin: 0 0 var(--space-md) 0;
			}
			.cta-button {
				display: inline-flex;
				align-items: center;
				gap: 8px;
				background-color: var(--oxblood);
				color: var(--iy-white);
				font-family: var(--font-sans);
				font-size: 12px;
				font-weight: 600;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				text-decoration: none;
				padding: 18px 36px;
				border: none;
				border-radius: 0;
				cursor: pointer;
				transition: background-color 0.3s ease;
			}
			.cta-button:hover {
				background-color: var(--oxblood-deep);
				color: var(--iy-white);
			}
			.cta-arrow {
				display: inline-block;
				transition: transform 0.3s ease;
			}
			.cta-button:hover .cta-arrow {
				transform: translateX(4px);
			}

			/* ===== Responsive ===== */
			@media (max-width: 768px) {
				.article-title {
					font-size: 32px;
				}
				.article-header {
					padding: var(--space-lg) var(--space-sm) 0;
				}
				.article-prose {
					padding: var(--space-md) var(--space-sm) var(--space-lg);
				}
				.cta-headline {
					font-size: var(--text-2xl);
				}
			}
			@media (max-width: 480px) {
				.article-title {
					font-size: 28px;
				}
			}
		</style>
		<SmoothScroll />
	</body>
</html>
