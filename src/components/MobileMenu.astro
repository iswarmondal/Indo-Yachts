---
import { Image } from "astro:assets";
import logoSailsRed from "../assets/images/Indo_Yachts_Sails_Red.png";
import logoSailsLight from "../assets/images/Indo_Yachts_Sails_Light.png";
---

<!-- Mobile Menu Overlay -->
<div class="mobile-menu-overlay" id="mobile-menu-overlay">
    <div class="mobile-menu" id="mobile-menu">
        <div class="mobile-menu__main">
            <div class="mobile-menu__header">
                <Image
                    src={logoSailsRed}
                    alt="Indo Yachts"
                    class="mobile-menu__logo"
                    width={64}
                    height={74}
                    quality={95}
                />
                <button
                    class="mobile-menu__close"
                    id="mobile-menu-close"
                    aria-label="Close menu"></button>
            </div>
            <div class="mobile-menu__body">
                <button class="mobile-menu__nav-item" data-panel="yachts">
                    <span class="mobile-menu__nav-title">Yachts</span>
                    <span class="mobile-menu__nav-arrow">→</span>
                </button>
                <button class="mobile-menu__nav-item" data-panel="destinations">
                    <span class="mobile-menu__nav-title">Destinations</span>
                    <span class="mobile-menu__nav-arrow">→</span>
                </button>
                <button class="mobile-menu__nav-item" data-panel="itineraries">
                    <span class="mobile-menu__nav-title">Itineraries</span>
                    <span class="mobile-menu__nav-arrow">→</span>
                </button>
                <div class="mobile-menu__divider"></div>
                <div class="mobile-menu__secondary">
                    <button
                        class="mobile-menu__secondary-item"
                        data-panel="about"
                    >
                        <span class="mobile-menu__secondary-title">About</span>
                        <span class="mobile-menu__secondary-arrow">→</span>
                    </button>
                    <button
                        class="mobile-menu__secondary-item"
                        data-panel="resources"
                    >
                        <span class="mobile-menu__secondary-title"
                            >Resources</span
                        >
                        <span class="mobile-menu__secondary-arrow">→</span>
                    </button>
                    <button
                        class="mobile-menu__secondary-item"
                        data-panel="contact"
                    >
                        <span class="mobile-menu__secondary-title">Contact</span
                        >
                        <span class="mobile-menu__secondary-arrow">→</span>
                    </button>
                </div>
            </div>
            <div class="mobile-menu__footer">
                <div class="mobile-menu__footer-accent"></div>
                <div class="mobile-menu__footer-inner">
                    <Image
                        src={logoSailsLight}
                        alt="Indo Yachts"
                        class="mobile-menu__footer-logo"
                        width={40}
                        height={46}
                        quality={95}
                    />
                    <a href="/contact/quote" class="mobile-menu__cta"
                        >Request a Quote</a
                    >
                </div>
                <div class="mobile-menu__footer-bottom"></div>
            </div>
        </div>

        <!-- ==========================================
       YACHTS PANEL
