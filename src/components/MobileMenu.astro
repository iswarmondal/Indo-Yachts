<script is:inline>
    (function () {
        var mobileMenu = document.getElementById("mobile-menu");
        var overlay = document.getElementById("mobile-menu-overlay");
        var closeBtn = document.getElementById("mobile-menu-close");

        // Close menu
        if (closeBtn) {
            closeBtn.addEventListener("click", function () {
                if (overlay) {
                    overlay.classList.remove("open");
                    document.body.style.overflow = "";
                }
            });
        }

        // Open panel
        var navItems = document.querySelectorAll(
            ".mobile-menu__nav-item[data-panel], .mobile-menu__secondary-item[data-panel]"
        );
        for (var i = 0; i < navItems.length; i++) {
            navItems[i].addEventListener("click", function () {
                var panelName = this.getAttribute("data-panel");
                var panel = document.getElementById("mm-panel-" + panelName);
                if (mobileMenu && panel) {
                    // Close any currently active panels first
                    var activePanels = mobileMenu.querySelectorAll(
                        ".mobile-menu__panel.active"
                    );
                    for (var j = 0; j < activePanels.length; j++) {
                        activePanels[j].classList.remove("active");
                    }
                    mobileMenu.classList.add("panel-open");
                    panel.classList.add("active");
                }
            });
        }

        // Close panel (back buttons)
        var backBtns = document.querySelectorAll("[data-mm-back]");
        for (var i = 0; i < backBtns.length; i++) {
            backBtns[i].addEventListener("click", function () {
                if (mobileMenu) {
                    mobileMenu.classList.remove("panel-open");
                    var panels = mobileMenu.querySelectorAll(
                        ".mobile-menu__panel"
                    );
                    for (var j = 0; j < panels.length; j++) {
                        panels[j].classList.remove("active");
                    }
                }
            });
        }

        // Tab switching functionality
        var tabs = document.querySelectorAll(".mm-panel__tab");
        for (var i = 0; i < tabs.length; i++) {
            tabs[i].addEventListener("click", function () {
                var tabId = this.getAttribute("data-mm-tab");
                var panel = this.closest(".mobile-menu__panel");

                // Remove active from all tabs in this panel
                var panelTabs = panel.querySelectorAll(".mm-panel__tab");
                for (var j = 0; j < panelTabs.length; j++) {
                    panelTabs[j].classList.remove("active");
                }

                // Hide all tab content in this panel
                var contents = panel.querySelectorAll(".mm-panel__tab-content");
                for (var j = 0; j < contents.length; j++) {
                    contents[j].classList.remove("active");
                }

                // Activate clicked tab
                this.classList.add("active");

                // Show corresponding content
                var content = document.getElementById(tabId);
                if (content) {
                    content.classList.add("active");
                }
            });
        }
    })();
</script>
