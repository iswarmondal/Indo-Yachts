---

<div class="lux-cursor" aria-hidden="true">
  <div class="lux-cursor__ring"></div>
  <div class="lux-cursor__dot"></div>
</div>

<style is:global>
  .has-lux-cursor,
  .has-lux-cursor * {
    cursor: none !important;
  }

  .lux-cursor {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 10001;
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .lux-cursor.is-visible {
    opacity: 1;
  }

  .lux-cursor__dot,
  .lux-cursor__ring {
    position: fixed;
    top: 0;
    left: 0;
    will-change: transform;
    pointer-events: none;
  }

  .lux-cursor__dot {
    width: 5px;
    height: 5px;
    margin: -2.5px 0 0 -2.5px;
    border-radius: 50%;
    background: var(--gold-light, #c4b896);
    transition:
      width 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      height 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      margin 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      background 0.35s ease;
  }

  .lux-cursor__ring {
    width: 36px;
    height: 36px;
    margin: -18px 0 0 -18px;
    border-radius: 50%;
    border: 1px solid rgba(196, 184, 150, 0.45);
    transition:
      width 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      height 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      margin 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.35s ease,
      background 0.35s ease;
  }

  .lux-cursor.is-hovering .lux-cursor__dot {
    width: 7px;
    height: 7px;
    margin: -3.5px 0 0 -3.5px;
    background: var(--gold-muted, #9a8b62);
  }

  .lux-cursor.is-hovering .lux-cursor__ring {
    width: 52px;
    height: 52px;
    margin: -26px 0 0 -26px;
    border-color: rgba(196, 184, 150, 0.65);
    background: rgba(196, 184, 150, 0.06);
  }

  .lux-reveal {
    opacity: 0;
    transform: translate3d(0, 28px, 0);
    transition:
      opacity 1s cubic-bezier(0.22, 1, 0.36, 1),
      transform 1s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--lux-reveal-delay, 0s);
  }

  .lux-reveal.is-visible {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  .section-header.lux-reveal.is-visible .section-header__label::after {
    transform: scaleX(1);
  }

  .section-header__label::after {
    content: "";
    display: block;
    width: 48px;
    height: 1px;
    margin: 14px auto 0;
    background: var(--gold-muted, #9a8b62);
    opacity: 0.45;
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 1.1s cubic-bezier(0.22, 1, 0.36, 1) 0.15s;
  }

  @media (prefers-reduced-motion: reduce) {
    .lux-cursor {
      display: none;
    }

    .lux-reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  @media (hover: none), (pointer: coarse) {
    .lux-cursor {
      display: none;
    }
  }
</style>

<script>
  import { initLuxuryInteractions } from "../scripts/luxury-interactions";

  initLuxuryInteractions();
</script>
