---
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${SITE_TITLE} — Luxury Yacht Charters`,
  description = SITE_DESCRIPTION,
} = Astro.props;
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="description" content={description} />
<title>{title}</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Manrope:wght@300;400;500;600&display=swap"
  rel="stylesheet"
  media="print"
  onload="this.media='all'"
/>
<noscript>
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Manrope:wght@300;400;500;600&display=swap"
    rel="stylesheet"
  />
</noscript>
<style is:global>
  :root {
    --oxblood: #953334;
    --oxblood-deep: #7a2a2b;
    --deep-sea: #0a1628;
    --navy-light: #0f1e33;
    --white: #ffffff;
    --snow: #fafafa;
    --cream: #f8f6f3;
    --cream-warm: #faf8f5;
    --sand: #e8e4de;
    --gold: #c9b97a;
    --text-primary: #0a1628;
    --text-muted: #888888;
    --text-light: #aaaaaa;
    --border: rgba(0, 0, 0, 0.06);
    --border-light: rgba(0, 0, 0, 0.04);
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: "Manrope", sans-serif;
    background: var(--cream);
    color: var(--deep-sea);
    -webkit-font-smoothing: antialiased;
  }

  /* =====================================================
		 CONTENT SECTIONS (for scroll testing)
		 ===================================================== */
  .content-section {
    padding: 120px 48px;
    max-width: 900px;
    margin: 0 auto;
  }

  .content-section h2 {
    font-family: "Cormorant Garamond", serif;
    font-size: 40px;
    font-weight: 400;
    margin-bottom: 24px;
    color: var(--deep-sea);
  }

  .content-section p {
    font-size: 16px;
    line-height: 1.8;
    color: #666;
    margin-bottom: 20px;
  }
</style>
