<script type="module">
  // Header scroll behavior — deferred until after load to improve LCP (Lighthouse)
  function initHeaderScroll() {
    const header = document.getElementById("header");
    if (!header) return;
    let lastScrollY = 0;
    let isHeaderHidden = false;
    const scrollThreshold = 100;

    function updateHeader() {
      const currentScrollY = window.scrollY;
      const scrollingDown = currentScrollY > lastScrollY;
      const scrollingUp = currentScrollY < lastScrollY;

      if (scrollingDown && currentScrollY > scrollThreshold && !isHeaderHidden) {
        header.classList.add("header-hidden");
        isHeaderHidden = true;
      }
      if (scrollingUp && isHeaderHidden) {
        header.classList.remove("header-hidden");
        isHeaderHidden = false;
      }
      if (currentScrollY <= 50) {
        header.classList.remove("header-light");
        header.classList.add("header-dark");
      } else if (!isHeaderHidden) {
        header.classList.remove("header-dark");
        header.classList.add("header-light");
      }
      lastScrollY = currentScrollY;
    }

    let scrollScheduled = false;
    function onScroll() {
      if (scrollScheduled) return;
      scrollScheduled = true;
      requestAnimationFrame(() => {
        scrollScheduled = false;
        updateHeader();
      });
    }
    window.addEventListener("scroll", onScroll, { passive: true });
    requestAnimationFrame(() => {
      lastScrollY = window.scrollY;
      updateHeader();
    });
  }
  if (document.readyState === "complete") setTimeout(initHeaderScroll, 0);
  else window.addEventListener("load", initHeaderScroll);
</script>

<style>
  /* =====================================================
     DROPDOWN STYLES (scoped to header)
     ===================================================== */
  .dropdown-trigger {
    position: relative;
    cursor: pointer;
  }

  .mega-menu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    background: white;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.25s ease,
      visibility 0.25s ease;
    z-index: 100;
    min-width: 800px;
    padding: 32px 40px;
    margin-top: 12px;
  }

  .dropdown-trigger:hover .mega-menu {
    opacity: 1;
    visibility: visible;
  }

  .mega-menu-grid {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 40px;
  }

  .mega-menu-list {
    list-style: none;
  }

  .mega-menu-label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #999;
    margin-bottom: 16px;
    font-family: "Manrope", sans-serif;
  }

  .mega-menu-item {
    display: block;
    text-decoration: none;
    padding: 12px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.04);
  }

  .mega-menu-item:last-child {
    border-bottom: none;
  }

  .mega-menu-name {
    display: block;
    font-family: "Cormorant Garamond", serif;
    font-size: 20px;
    font-weight: 400;
    color: var(--deep-sea);
    transition: color 0.2s;
  }

  .mega-menu-item:hover .mega-menu-name {
    color: var(--oxblood);
  }

  .mega-menu-meta {
    display: block;
    font-size: 12px;
    color: #999;
    margin-top: 4px;
    font-family: "Manrope", sans-serif;
  }

  .mega-menu-featured {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .mega-menu-card {
    display: block;
    text-decoration: none;
  }

  .mega-menu-card-image {
    aspect-ratio: 3/2;
    overflow: hidden;
    background: #f0f0f0;
    margin-bottom: 12px;
  }

  .mega-menu-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .mega-menu-card:hover .mega-menu-card-image img {
    transform: scale(1.05);
  }

  .mega-menu-card-label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--oxblood);
    margin-bottom: 6px;
    font-family: "Manrope", sans-serif;
  }

  .mega-menu-card-title {
    font-family: "Cormorant Garamond", serif;
    font-size: 22px;
    font-weight: 400;
    color: var(--deep-sea);
    transition: color 0.2s;
  }

  .mega-menu-card:hover .mega-menu-card-title {
    color: var(--oxblood);
  }

  .mega-menu-card-meta {
    font-size: 12px;
    color: #999;
    margin-top: 4px;
    font-family: "Manrope", sans-serif;
  }

  .mega-menu-footer {
    margin-top: 24px;
    padding-top: 20px;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
  }

  .mega-menu-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 500;
    color: var(--oxblood);
    text-decoration: none;
    transition: gap 0.2s;
    font-family: "Manrope", sans-serif;
  }

  .mega-menu-cta:hover {
    gap: 12px;
  }

  .mega-menu-cta svg {
    width: 16px;
    height: 16px;
  }

  .simple-dropdown {
    position: absolute;
    top: 100%;
    right: 0;
    background: white;
    box-shadow: 0 15px 50px rgba(0, 0, 0, 0.12);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition:
      opacity 0.2s ease,
      transform 0.2s ease,
      visibility 0.2s;
    z-index: 100;
    min-width: 220px;
    padding: 24px;
    margin-top: 12px;
    border-top: 3px solid var(--oxblood);
  }

  .dropdown-trigger:hover .simple-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .simple-dropdown-list {
    list-style: none;
  }

  .simple-dropdown-item {
    display: block;
    text-decoration: none;
    padding: 10px 0;
  }

  .simple-dropdown-item span {
    font-family: "Cormorant Garamond", serif;
    font-size: 18px;
    color: var(--deep-sea);
    transition: color 0.2s;
  }

  .simple-dropdown-item:hover span {
    color: var(--oxblood);
  }

  .simple-dropdown-footer {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
  }

  /* =====================================================
     HEADER STYLES
     ===================================================== */
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    transition:
      transform 0.3s ease,
      background 0.3s ease,
