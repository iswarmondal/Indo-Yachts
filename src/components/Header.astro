  }

  .header.header-hidden {
    transform: translateY(-100%);
  }

  .header.header-dark {
    background: transparent;
  }

  .header.header-light {
    background: white;
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.06);
    border-bottom: none;
  }

  .header .header-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 96px;
    position: relative;
  }

  .header nav {
    display: flex;
    align-items: center;
  }

  .header .nav-link {
    font-family: "Cormorant Garamond", serif;
    font-size: 18px;
    font-weight: 400;
    color: white;
    text-decoration: none;
    transition: color 0.2s;
    padding: 12px 20px;
    letter-spacing: 0.02em;
  }

  .header.header-light .nav-link {
    color: var(--deep-sea);
  }

  .header .nav-link:hover {
    color: var(--oxblood);
  }

  .header.header-dark .nav-link:hover {
    color: rgba(255, 255, 255, 0.7);
  }

  .header .logo {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  .header .logo img {
    height: 36px;
  }

  .header .logo-light {
    display: block;
  }

  .header .logo-dark {
    display: none;
  }

  .header.header-light .logo-light {
    display: none;
  }

  .header.header-light .logo-dark {
    display: block;
  }

  .header .mega-menu {
    left: 0;
    transform: none;
    right: 0;
    margin-top: 12px;
    border-top: 3px solid var(--oxblood);
  }

  .header .nav-right {
    gap: 4px;
  }

  .header .nav-right .nav-link {
    padding: 12px 16px;
  }
</style>
