        font-weight: 600;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--gold-muted);
        margin-bottom: 10px;
      }

      .dest-card__title {
        font-family: "Cormorant Garamond", serif;
        font-size: 30px;
        font-weight: 300;
        color: var(--white);
        line-height: 1.15;
        margin-bottom: 8px;
      }

      .dest-card__tagline {
        font-family: "Manrope", sans-serif;
        font-size: 13px;
        font-weight: 400;
        color: rgba(255, 255, 255, 0.75);
        line-height: 1.5;
      }

      .dest-card__cta {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--white);
        margin-top: 16px;
        opacity: 0;
        transform: translateY(10px);
        transition: all 0.3s ease;
      }

      .dest-card:hover .dest-card__cta {
        opacity: 1;
