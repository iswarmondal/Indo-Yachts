      }

      .dest-card__season-dot--shoulder {
        background: var(--shoulder);
      }

      .dest-card__season-text {
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--slate);
      }

      .dest-card__content {
        position: absolute;
        bottom: 0;
        left: 0;
