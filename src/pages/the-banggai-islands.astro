      .yacht-card__badge {
        position: absolute;
        top: 24px;
        left: 24px;
        background: var(--white);
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--oxblood);
        padding: 10px 16px;
        z-index: 1;
      }

      .yacht-card__content {
        padding: 28px 32px 32px;
      }

      .yacht-card__name {
        font-family: "Cormorant Garamond", serif;
        font-size: 32px;
        font-weight: 300;
        margin-bottom: 8px;
        letter-spacing: 0.01em;
      }

      .yacht-card__specs {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.5);
        margin-bottom: 28px;
        letter-spacing: 0.02em;
      }

      .yacht-card__footer {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
      }

      .yacht-card__cta {
        font-size: 12px;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: 8px;
