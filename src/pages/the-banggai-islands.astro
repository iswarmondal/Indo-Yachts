  <!-- ════════════════════════════════════════════════════════════════
       FAQ SECTION
       ════════════════════════════════════════════════════════════════ -->
  <section id="faq" class="section section--cream">
    <div class="section__inner">
      <div class="section-header">
        <span class="section-header__label">Questions</span>
        <h2 class="section-header__title">Banggai Islands FAQ</h2>
      </div>

      <!-- First 4 FAQs (always visible) -->
      <div class="faq-grid">
        <div class="faq-item">
          <h3 class="faq-item__question">
            What's the best time to visit the Banggai Islands?
          </h3>
          <p class="faq-item__answer">
            Ideally September to November-seas calmest, rain manageable. Avoid
            the peak of the monsoon (Dec-Feb) unless you have buffer time for
            delays. Paisupok Lake is clear year-round.
          </p>
        </div>

        <div class="faq-item">
          <h3 class="faq-item__question">How do I get there?</h3>
          <p class="faq-item__answer">
            Fly to Luwuk (LWK) on the Sulawesi mainland (usually via Makassar).
            Taxi to the harbor, then take the wooden ferry to Leme-Leme (Peleng)
            or the fast boat to Salakan. Pre-arrange pickup to Luk Panenteng.
          </p>
        </div>

        <div class="faq-item">
          <h3 class="faq-item__question">Is it suitable for everyone?</h3>
          <p class="faq-item__answer">
            If you are patient, self-sufficient, and willing to trade comfort
            for silence, the Banggai Islands are remarkable. If you need
            seamless transfers and air-conditioned cafes, consider a different
            destination.
          </p>
        </div>

        <div class="faq-item">
          <h3 class="faq-item__question">How much cash do I need?</h3>
          <p class="faq-item__answer">
            Bring all the cash you think you need, then add 30%. Accommodation
            ~250-400K IDR/night; car charter ~700K/day; boat charters 800K-1.5M
            IDR. ATMs in Luwuk and Salakan; often reject foreign cards in
            Banggai Town.
          </p>
        </div>
      </div>

      <!-- Additional 4 FAQs (hidden by default) -->
      <div class="faq-grid faq-grid--hidden" id="faqMore">
        <div class="faq-item">
          <h3 class="faq-item__question">What about accommodation?</h3>
          <p class="faq-item__answer">
            Luk Panenteng: rustic homestays, electricity 6 PM-6 AM, mandi-style
            bathrooms, meals included. Salakan: government-style transit hotels.
            Banggai Town: older hotels with AC; ask to see the room before
            paying.
          </p>
        </div>

        <div class="faq-item">
          <h3 class="faq-item__question">Do I need to speak Indonesian?</h3>
          <p class="faq-item__answer">
            English is virtually non-existent outside a few guides. Use Google
            Translate offline; learn basic phrases (e.g. kanan, kiri, mahal, jam
            berapa?). Booking homestays often via Google Maps + WhatsApp.
          </p>
        </div>

        <div class="faq-item">
          <h3 class="faq-item__question">Is there mobile coverage?</h3>
          <p class="faq-item__answer">
            Telkomsel is the only carrier that matters. 4G in Salakan and
            Banggai Town; 3G or Edge in Luk Panenteng. Large dead zones on the
            roads. Download offline maps.
          </p>
        </div>

        <div class="faq-item">
          <h3 class="faq-item__question">
            Can I see the Banggai Cardinalfish without a boat?
          </h3>
          <p class="faq-item__answer">
            Yes. Walk to the main jetty in Banggai Town and look down into the
            water between the pilings-hundreds of Cardinalfish hover among the
            sea urchins under the busy commercial dock.
          </p>
        </div>
      </div>

      <div class="view-more-wrapper">
        <button class="link-toggle" id="viewMoreFaqBtn" onclick="toggleFaq()">
          <span class="link-toggle__text">SHOW MORE FAQ</span>
          <svg class="link-toggle__arrow" viewBox="0 0 24 24"
            ><polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </button>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════
       CTA BANNER
       ════════════════════════════════════════════════════════════════ -->
  <section class="cta-banner">
    <div class="cta-banner__inner">
      <h2 class="cta-banner__title">Ready to explore the Banggai Islands?</h2>
      <p class="cta-banner__text">
        Tell us your dates and interests. We can help you plan a realistic<br
        />itinerary for Sulawesi's fragile archipelago.
      </p>
      <button class="cta-banner__button" id="openModalBtn">
        Plan Your Trip <span>→</span>
      </button>
    </div>
  </section>

  <main>
    <!-- Modal Overlay -->
    <div class="modal-overlay" id="formModal">
      <div class="modal" onclick="event.stopPropagation()">
        <button class="modal__close" id="closeModalBtn" aria-label="Close">
          <svg
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
        <div class="modal__content" id="modalContent">
          <div class="modal__header">
            <p class="modal__eyebrow">Explore the Banggai Islands</p>
            <h3 class="modal__headline">Plan Your Banggai Islands Trip</h3>
            <p class="modal__body">
              Share your dates and group size and we'll help you plan a
              realistic itinerary for the Banggai Islands.
            </p>
          </div>
          <form id="inquiryForm">
            <div class="form__row">
              <div class="form__field">
                <input
                  type="text"
                  name="name"
                  placeholder="Your Name"
                  required
                />
              </div>
              <div class="form__field">
                <input type="tel" name="phone" placeholder="Phone Number" />
              </div>
            </div>
            <div class="form__field">
              <input
                type="email"
                name="email"
                placeholder="Email Address"
                required
              />
            </div>
            <div class="form__row">
              <div class="form__field">
                <select name="guests" required>
                  <option value="" disabled selected>Group Size</option>
                  <option value="2-4">2-4 Guests</option>
                  <option value="5-8">5-8 Guests</option>
                  <option value="9-12">9-12 Guests</option>
                  <option value="13-16">13-16 Guests</option>
                  <option value="17+">17+ Guests</option>
                </select>
              </div>
              <div class="form__field">
                <select name="budget">
                  <option value="" disabled selected>Budget (Per Week)</option>
                  <option value="under-50k">Under $50,000</option>
                  <option value="50k-80k">$50,000 - $80,000</option>
                  <option value="80k-120k">$80,000 - $120,000</option>
                  <option value="120k+">$120,000+</option>
                  <option value="flexible">Flexible</option>
                </select>
              </div>
            </div>
            <div class="form__field">
              <textarea
                name="details"
                placeholder="Dates you're considering, destinations that interest you, or anything else that helps us personalize your recommendations."
              ></textarea>
            </div>
            <input
              type="hidden"
              name="source"
              value="destination-banggai-islands"
            />
            <input type="hidden" name="destination" value="Banggai Islands" />
            <button type="submit" class="form__submit"
              >Plan Your Voyage <span>→</span>
            </button>
          </form>
        </div>
      </div>
    </div>
  </main>
  <script>
    // Dive Sites Toggle
    const diveSitesBtn = document.getElementById("viewMoreBtn");
    if (diveSitesBtn) {
      diveSitesBtn.addEventListener("click", function () {
        const moreSection = document.getElementById("diveSitesMore");
        if (!moreSection) return;
        const btn = this;
        if (!btn) return;

        const textSpan = btn.querySelector(".link-toggle__text");
        if (moreSection.classList.contains("active")) {
          moreSection.classList.remove("active");
          btn.classList.remove("link-toggle--expanded");
          if (textSpan) {
            textSpan.textContent = "VIEW MORE HIGHLIGHTS";
          }
        } else {
          moreSection.classList.add("active");
          btn.classList.add("link-toggle--expanded");
          if (textSpan) {
            textSpan.textContent = "VIEW LESS HIGHLIGHTS";
          }
        }
      });
    }

    // FAQ Toggle
    const faqBtn = document.getElementById("viewMoreFaqBtn");
    if (faqBtn) {
      faqBtn.addEventListener("click", function () {
        const moreSection = document.getElementById("faqMore");
        if (!moreSection) return;
        const btn = this; // Use specific button
        if (!btn) return;

        const textSpan = btn.querySelector(".link-toggle__text");
        if (moreSection.classList.contains("active")) {
          moreSection.classList.remove("active");
          btn.classList.remove("link-toggle--expanded");
          if (textSpan) textSpan.textContent = "SHOW MORE FAQ";
        } else {
          moreSection.classList.add("active");
          btn.classList.add("link-toggle--expanded");
          if (textSpan) textSpan.textContent = "SHOW LESS FAQ";
        }
      });
    }

    // Modal Functions
    const modal = document.getElementById("formModal");
    const openBtn = document.getElementById("openModalBtn");
    const closeBtn = document.getElementById("closeModalBtn");
    // const modalContent = document.querySelector(".modal"); // unused
    const form = document.getElementById("inquiryForm");

    if (openBtn && modal) {
      openBtn.addEventListener("click", function () {
        modal.classList.add("active");
        document.body.style.overflow = "hidden";
        setTimeout(() => {
          const firstInput = document.querySelector(
            '.modal input[name="name"]'
          ) as HTMLInputElement | null;
          if (firstInput) firstInput.focus();
        }, 400);
      });
    }

    if (closeBtn && modal) {
      closeBtn.addEventListener("click", closeModal);
    }

    if (modal) {
      modal.addEventListener("click", function (event) {
        if (event.target === modal) {
          closeModal();
        }
      });
    }

    function closeModal() {
      if (modal) {
        modal.classList.remove("active");
        document.body.style.overflow = "";
      }
    }

    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape") closeModal();
    });

    if (form) {
      form.addEventListener("submit", function (event) {
        event.preventDefault();
        const content = document.getElementById("modalContent");
        if (content) {
          content.innerHTML = `
            <div class="form-success">
              <svg class="form-success__icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <h3 class="form-success__title">Thank You</h3>
              <p class="form-success__text">We'll be in touch within 24 hours with personalized recommendations for your voyage.</p>
              <button class="form-success__close" id="successCloseBtn">Close</button>
            </div>
          `;
          // Re-attach close listener to new button
          const newClose = document.getElementById("successCloseBtn");
          if (newClose) newClose.addEventListener("click", closeModal);
        }
      });
    }
  </script>

  <!-- Mobile Menu Hamburger Trigger -->
  <script is:inline>
    (function () {
      var hamburgerBtn = document.getElementById("mobile-hamburger-btn");
      var mobileOverlay = document.getElementById("mobile-menu-overlay");
      if (hamburgerBtn && mobileOverlay) {
        hamburgerBtn.addEventListener("click", function () {
          mobileOverlay.classList.add("open");
          document.body.style.overflow = "hidden";
        });
      }
    })();
  </script>


</html>
