        align-items: center;
        gap: 10px;
        font-family: "Manrope", sans-serif;
        font-size: 12px;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #722f37;
        text-decoration: none;
        transition: all 0.3s ease;
      }

      .section-footer__link:hover {
        color: #5a252c;
        gap: 14px;
      }

      .section-footer__link svg {
        width: 14px;
        height: 14px;
      }

      /* ════════════════════════════════════════════════════════════════
       FAQ SECTION
       ════════════════════════════════════════════════════════════════ */
      .faq-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 24px;
      }

      .faq-item {
        background: var(--white);
        padding: 32px;
        border-left: 3px solid var(--oxblood);
      }

      .faq-item__question {
        font-family: "Cormorant Garamond", serif;
        font-size: 20px;
        font-weight: 400;
        color: var(--deep-sea);
        margin-bottom: 12px;
        line-height: 1.3;
      }

      .faq-item__answer {
        font-size: 14px;
        line-height: 1.8;
        color: var(--slate);
      }

      @media (max-width: 900px) {
        .faq-grid {
          grid-template-columns: 1fr;
        }
      }

      .faq-grid--hidden {
        display: none;
        margin-top: 24px;
      }
      .faq-grid--hidden.active {
        display: grid;
      }

      /* ════════════════════════════════════════════════════════════════
       CTA BANNER (Standardized Blue)
       ════════════════════════════════════════════════════════════════ */
      .cta-banner {
        background: var(--deep-sea);
        padding: 100px 48px;
        text-align: center;
      }

      .cta-banner__inner {
        max-width: 620px;
        margin: 0 auto;
      }

      .cta-banner__title {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(28px, 4vw, 38px);
        font-weight: 300;
        color: var(--white);
        margin-bottom: 20px;
        line-height: 1.2;
      }

      .cta-banner__text {
        font-family: "Manrope", sans-serif;
        font-size: 15px;
        line-height: 1.8;
        color: rgba(255, 255, 255, 0.7);
        margin-bottom: 36px;
      }

      .cta-banner__button {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        background: var(--oxblood);
        color: var(--white);
        padding: 18px 36px;
        font-family: "Manrope", sans-serif;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        text-decoration: none;
        border: none;
        cursor: pointer;
        transition: all 0.4s ease;
      }

      .cta-banner__button:hover {
        background: var(--oxblood-deep);
        gap: 16px;
      }

      .cta-banner__button span {
        transition: transform 0.3s ease;
      }

      .cta-banner__button:hover span {
