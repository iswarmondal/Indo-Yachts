---
import Header from "../components/Header.astro";
import BaseHead from "../components/BaseHead.astro";
import { Image } from "astro:assets";
import heroPhinisi from "../assets/images/hero-phinisi.jpg";
import wayagAerial from "../assets/images/wayag-aerial.jpg";
import coralReef from "../assets/images/coral-reef.jpg";
import mantaRays from "../assets/images/manta-rays.jpg";
import wayagSunset from "../assets/images/wayag-sunset.jpg";
import misoolLagoon from "../assets/images/misool-lagoon.jpg";
import caveDiving from "../assets/images/cave-diving.jpg";
import beachTurquoise from "../assets/images/beach-turquoise.jpg";
import softCoralMangrove from "../assets/images/soft-coral-mangrove.jpg";
import karstTurquoise from "../assets/images/karst-turquoise.jpg";
import splitShot from "../assets/images/split-shot.jpg";
import duniaBaru from "../assets/images/dunia-baru.jpg";
---

<!doctype html>
<html lang="en">
  <head>
    <meta
      name="description"
      content="Discover the breathtaking beauty and rich biodiversity of the Banggai Islands. Explore travel tips, local culture, and experiences in this unique Indonesian paradise."
    />
    <BaseHead />
    <style>
      :root {
        --oxblood: #953334;
        --oxblood-deep: #722728;
        --oxblood-light: #a84445;
        --deep-sea: #0a1628;
        --deep-sea-light: #142238;
        --white: #ffffff;
        --snow: #fafafa;
        --cream: #f8f6f3;
        --sand: #e8e4de;
        --charcoal: #1a1a1a;
        --slate: #4a4a4a;
        --silver: #6c6b6b;
        --gold-muted: #b8a878;
        --peak: #2d6a4f;
        --shoulder: #c17f24;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      html {
        font-size: 16px;
        -webkit-font-smoothing: antialiased;
        scroll-behavior: smooth;
      }
      body {
        font-family: "Manrope", sans-serif;
        background: var(--white);
        color: var(--charcoal);
      }
      /* ════════════════════════════════════════════════════════════════
       HERO - CONCEPT B EDITORIAL FRAME
       ════════════════════════════════════════════════════════════════ */
      .hero {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        background: var(--snow);
      }

      .hero__frame {
        flex: 1;
        position: relative;
        margin: 24px 0px;
        margin-top: 0;
        margin-bottom: 0;
        overflow: hidden;
        min-height: 500px;
      }

      .hero__image {
        position: absolute;
        inset: 0;
      }

      .hero__image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .hero__overlay {
        position: absolute;
        inset: 0;
        background:
          linear-gradient(
            to bottom,
            rgba(10, 22, 40, 0.5) 0%,
            rgba(10, 22, 40, 0.2) 15%,
            transparent 30%
          ),
          linear-gradient(
            to top,
            rgba(10, 22, 40, 0.75) 0%,
            rgba(10, 22, 40, 0.25) 40%,
            transparent 70%
          );
      }

      .hero__content {
        position: absolute;
        bottom: 60px;
        left: 8%;
        right: 8%;
        z-index: 2;
      }

      .hero__eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 16px;
      }

      .hero__eyebrow-line {
        width: 40px;
        height: 1px;
        background: var(--gold-muted);
      }

      .hero__eyebrow-text {
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: var(--gold-muted);
      }

      .hero__title {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(52px, 8vw, 88px);
        font-weight: 300;
        font-style: italic;
        color: var(--white);
        letter-spacing: 0.02em;
        line-height: 0.95;
        margin-bottom: 16px;
      }

      .hero__tagline {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(18px, 2vw, 22px);
        font-weight: 300;
        font-style: italic;
        color: rgba(255, 255, 255, 0.85);
      }

      .hero__scroll {
        position: absolute;
        bottom: 60px;
        right: 8%;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
      }

      .hero__scroll-text {
        font-size: 10px;
        font-weight: 500;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.5);
      }

      .hero__scroll-line {
        width: 1px;
        height: 40px;
        background: linear-gradient(
          to bottom,
          rgba(255, 255, 255, 0.4),
          transparent
        );
        animation: scrollPulse 2s ease-in-out infinite;
      }

      @keyframes scrollPulse {
        0%,
        100% {
          opacity: 1;
          transform: scaleY(1);
        }
        50% {
          opacity: 0.5;
          transform: scaleY(0.8);
        }
      }

      @media (max-width: 900px) {
        .hero__frame {
          margin: 0;
        }
        .hero__content {
          left: 24px;
          right: 24px;
          bottom: 40px;
        }
        .hero__scroll {
          display: none;
        }
      }

      /* ════════════════════════════════════════════════════════════════
       INFO FOOTER - TRUST BAR (LIGHT STYLE)
       ════════════════════════════════════════════════════════════════ */
      .info-footer {
        padding: 40px 8%;
        background: var(--snow);
      }

      .info-footer__inner {
        display: flex;
        justify-content: center;
        gap: 80px;
        flex-wrap: wrap;
      }

      .info-footer__item {
        text-align: center;
      }

      .info-footer__value {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(20px, 2.5vw, 26px);
        font-weight: 300;
        color: var(--deep-sea);
        margin-bottom: 8px;
      }

      .info-footer__label {
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--silver);
      }

      @media (max-width: 900px) {
        .info-footer {
          padding: 32px 24px;
        }
        .info-footer__inner {
          gap: 32px;
        }
        .info-footer__item {
          flex: 1 1 45%;
        }
      }

      /* ════════════════════════════════════════════════════════════════
       SECTIONS
       ════════════════════════════════════════════════════════════════ */
      .section {
        padding: 100px 48px;
      }
      .section--white {
        background: var(--white);
      }
      .section--snow {
        background: var(--snow);
      }
      .section--cream {
        background: var(--cream);
      }
      .section--deep {
        background: var(--deep-sea);
        color: var(--white);
      }
      .section__inner {
        max-width: 1400px;
        margin: 0 auto;
      }

      @media (max-width: 768px) {
        .section {
          padding: 60px 24px;
        }
      }

      /* Section Headers */
      .section-header {
        text-align: center;
        margin-bottom: 60px;
      }

      .section-header__label {
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: var(--oxblood);
        margin-bottom: 16px;
      }

      .section-header__title {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(32px, 5vw, 42px);
        font-weight: 300;
        color: var(--deep-sea);
        line-height: 1.15;
        margin-bottom: 20px;
      }

      .section-header__subtitle {
        font-size: 15px;
        line-height: 1.9;
        color: var(--slate);
        max-width: 700px;
        margin: 0 auto;
      }

      .section--deep .section-header__label {
        color: var(--gold-muted);
      }
      .section--deep .section-header__title {
        color: var(--white);
      }
      .section--deep .section-header__subtitle {
        color: rgba(255, 255, 255, 0.7);
      }

      /* ════════════════════════════════════════════════════════════════
       OVERVIEW - TEXT + IMAGE
       ════════════════════════════════════════════════════════════════ */
      .overview-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        align-items: start;
      }

      .overview__text h2 {
        font-family: "Cormorant Garamond", serif;
        font-size: 36px;
        font-weight: 300;
        color: var(--deep-sea);
        margin-bottom: 28px;
        line-height: 1.2;
      }

      .overview__text h3 {
        font-family: "Cormorant Garamond", serif;
        font-size: 24px;
        font-weight: 400;
        color: var(--deep-sea);
        margin: 32px 0 16px;
      }

      .overview__text p {
        font-size: 15px;
        line-height: 1.95;
        color: var(--slate);
        margin-bottom: 20px;
      }

      .overview__text p strong {
        color: var(--deep-sea);
      }

      .overview__image {
      }
      .overview__image img {
        width: 100%;
        height: auto;
      }

      .overview__image-caption {
        font-size: 12px;
        color: var(--silver);
        margin-top: 12px;
        text-align: center;
        font-style: italic;
      }

      @media (max-width: 1000px) {
        .overview-grid {
          grid-template-columns: 1fr;
          gap: 40px;
        }
      }

      /* Featured Quote - Full Width */
      .featured-quote {
        background: var(--deep-sea);
        padding: 100px 48px;
        text-align: center;
        position: relative;
      }

      .featured-quote::before {
        content: '"';
        position: absolute;
        top: 40px;
        left: 50%;
        transform: translateX(-50%);
        font-family: "Cormorant Garamond", serif;
        font-size: 180px;
        font-weight: 300;
        color: var(--oxblood);
        opacity: 0.3;
        line-height: 1;
      }

      .featured-quote__inner {
        max-width: 900px;
        margin: 0 auto;
        position: relative;
        z-index: 1;
      }

      .featured-quote__text {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(28px, 4vw, 40px);
        font-weight: 300;
        font-style: italic;
        color: var(--white);
        line-height: 1.4;
        margin-bottom: 24px;
      }

      .featured-quote__attribution {
        font-size: 14px;
        color: var(--gold-muted);
        letter-spacing: 0.05em;
      }

      /* Two Column with Image */
      .two-col-with-image {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        align-items: start;
      }

      .two-col-with-image__text h3 {
        font-family: "Cormorant Garamond", serif;
        font-size: 36px;
        font-weight: 300;
        color: var(--deep-sea);
        margin-bottom: 24px;
        line-height: 1.2;
      }

      .two-col-with-image__text p {
        font-size: 15px;
        line-height: 1.9;
        color: var(--slate);
        margin-bottom: 16px;
      }

      .two-col-with-image__text p strong {
        color: var(--deep-sea);
      }

      .two-col-with-image__image img {
        width: 100%;
        height: auto;
      }

      @media (max-width: 900px) {
        .two-col-with-image {
          grid-template-columns: 1fr;
          gap: 40px;
        }
      }

      /* Highlight Box */
      .highlight-box {
        background: var(--cream);
        padding: 32px;
        margin: 32px 0;
        border-left: 3px solid var(--oxblood);
      }

      .highlight-box__title {
        font-family: "Cormorant Garamond", serif;
        font-size: 20px;
        font-weight: 400;
        color: var(--deep-sea);
        margin-bottom: 12px;
      }

      .highlight-box p {
        font-size: 14px;
        line-height: 1.8;
        color: var(--slate);
        margin: 0;
      }

      /* Experience Grid */
      .experience-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        margin-top: 60px;
      }

      .experience-card {
        background: var(--snow);
        padding: 40px;
      }

      .experience-card__title {
        font-family: "Cormorant Garamond", serif;
        font-size: 24px;
        font-weight: 400;
        color: var(--deep-sea);
        margin-bottom: 16px;
      }

      .experience-card p {
        font-size: 14px;
        line-height: 1.8;
        color: var(--slate);
      }

      @media (max-width: 768px) {
        .experience-grid {
          grid-template-columns: 1fr;
          gap: 24px;
        }
      }

      /* Beyond Underwater - Full Width Feature */
      .beyond-section {
        background: var(--cream);
        padding: 100px 48px;
        position: relative;
      }

      .beyond-section__inner {
        max-width: 1400px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        align-items: center;
      }

      .beyond-section__content {
        position: relative;
      }

      .beyond-section__label {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--oxblood);
        margin-bottom: 20px;
      }

      .beyond-section__label::before {
        content: "";
        width: 40px;
        height: 1px;
        background: var(--oxblood);
      }

      .beyond-section__content h2 {
        font-family: "Cormorant Garamond", serif;
        font-size: 36px;
        font-weight: 300;
        color: var(--deep-sea);
        margin-bottom: 24px;
        line-height: 1.2;
      }

      .beyond-section__content p {
        font-size: 15px;
        line-height: 1.9;
        color: var(--slate);
        margin-bottom: 20px;
      }

      .beyond-section__content p strong {
        color: var(--deep-sea);
      }

      .beyond-section__highlights {
        display: flex;
        gap: 32px;
        margin-top: 32px;
        padding-top: 28px;
        border-top: 1px solid var(--sand);
      }

      .beyond-section__highlight {
        flex: 1;
      }

      .beyond-section__highlight-title {
        font-family: "Cormorant Garamond", serif;
        font-size: 18px;
        font-weight: 400;
        color: var(--deep-sea);
        margin-bottom: 6px;
      }

      .beyond-section__highlight-text {
        font-size: 13px;
        color: var(--silver);
        line-height: 1.6;
      }

      .beyond-section__image {
        position: relative;
      }

      .beyond-section__image img {
        width: 100%;
        height: auto;
      }

      .beyond-section__image-accent {
        position: absolute;
        bottom: -20px;
        left: -20px;
        width: 120px;
        height: 120px;
        border: 1px solid var(--gold-muted);
        opacity: 0.4;
        z-index: -1;
      }

      @media (max-width: 900px) {
        .beyond-section {
          padding: 60px 24px;
        }
        .beyond-section__inner {
          grid-template-columns: 1fr;
          gap: 40px;
        }
        .beyond-section__highlights {
          flex-direction: column;
          gap: 20px;
        }
        .beyond-section__image-accent {
          display: none;
        }
      }

      /* Indo Yachts Experience - Left-Aligned Bounded (V1) */
      .expertise-hero {
        position: relative;
        min-height: 600px;
        overflow: hidden;
      }

      .expertise-hero__image {
        position: absolute;
        inset: 0;
      }

      .expertise-hero__image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .expertise-hero__overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
          to right,
          rgba(10, 22, 40, 0.92) 0%,
          rgba(10, 22, 40, 0.85) 35%,
          rgba(10, 22, 40, 0.5) 60%,
          rgba(10, 22, 40, 0.2) 100%
        );
      }

      .expertise-hero__inner {
        position: relative;
        z-index: 2;
        max-width: 1400px;
        margin: 0 auto;
        padding: 100px 48px;
        display: flex;
        align-items: center;
        min-height: 600px;
      }

      .expertise-hero__content {
        max-width: 580px;
      }

      .expertise-hero__label {
        display: inline-flex;
        align-items: center;
        gap: 16px;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--gold-muted);
        margin-bottom: 24px;
      }

      .expertise-hero__label::after {
        content: "";
        width: 60px;
        height: 1px;
        background: var(--gold-muted);
        opacity: 0.4;
      }

      .expertise-hero__title {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(40px, 5vw, 56px);
        font-weight: 300;
        color: var(--white);
        line-height: 1.1;
        margin-bottom: 28px;
      }

      .expertise-hero__text {
        font-size: 16px;
        line-height: 1.9;
        color: rgba(255, 255, 255, 0.8);
        margin-bottom: 16px;
      }

      .expertise-hero__stats {
        display: flex;
        gap: 48px;
        margin-top: 40px;
        padding-top: 32px;
        border-top: 1px solid rgba(255, 255, 255, 0.15);
      }

      .expertise-hero__stat-value {
        font-family: "Cormorant Garamond", serif;
        font-size: 40px;
        font-weight: 300;
        color: var(--white);
        line-height: 1;
        margin-bottom: 6px;
      }

      .expertise-hero__stat-label {
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--gold-muted);
      }

      @media (max-width: 900px) {
        .expertise-hero {
          min-height: 650px;
        }
        .expertise-hero__overlay {
          background: linear-gradient(
            to top,
            rgba(10, 22, 40, 0.95) 0%,
            rgba(10, 22, 40, 0.8) 50%,
            rgba(10, 22, 40, 0.5) 100%
          );
        }
        .expertise-hero__inner {
          padding: 60px 24px;
          align-items: flex-end;
        }
        .expertise-hero__content {
          max-width: 100%;
        }
        .expertise-hero__stats {
          flex-wrap: wrap;
          gap: 32px;
        }
      }

      /* ════════════════════════════════════════════════════════════════
       REGIONS - THE FOUR KINGDOMS
       ════════════════════════════════════════════════════════════════ */
      .region-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
      }

      .region-card {
        background: var(--white);
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(10, 22, 40, 0.06);
      }

      .region-card__image {
        aspect-ratio: 16/10;
        overflow: hidden;
      }

      .region-card__image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 1s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      }

      .region-card:hover .region-card__image img {
        transform: scale(1.05);
      }

      .region-card__content {
        padding: 32px;
      }

      .region-card__label {
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--oxblood);
        margin-bottom: 12px;
      }

      .region-card__title {
        font-family: "Cormorant Garamond", serif;
        font-size: 28px;
        font-weight: 300;
        color: var(--deep-sea);
        margin-bottom: 16px;
      }

      .region-card__desc {
        font-size: 14px;
        line-height: 1.8;
        color: var(--slate);
        margin-bottom: 20px;
      }

      .region-card__highlights {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      .region-card__highlight {
        padding: 6px 12px;
        background: var(--snow);
        font-size: 11px;
        font-weight: 500;
        color: var(--slate);
      }

      @media (max-width: 1100px) {
        .region-grid {
          grid-template-columns: 1fr;
        }
      }

      /* ════════════════════════════════════════════════════════════════
       DIVE SITES
       ════════════════════════════════════════════════════════════════ */
      .dive-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 24px;
      }

      .dive-card {
        background: var(--white);
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(10, 22, 40, 0.06);
        transition:
          transform 0.3s ease,
          box-shadow 0.3s ease;
      }

      .dive-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 32px rgba(10, 22, 40, 0.1);
      }

      .dive-card__image {
        aspect-ratio: 4/3;
        overflow: hidden;
      }

      .dive-card__image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.8s ease;
      }

      .dive-card:hover .dive-card__image img {
        transform: scale(1.05);
      }

      .dive-card__content {
        padding: 24px;
      }

      .dive-card__region {
        font-size: 9px;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--oxblood);
        margin-bottom: 8px;
      }

      .dive-card__title {
        font-family: "Cormorant Garamond", serif;
        font-size: 22px;
        font-weight: 400;
        color: var(--deep-sea);
        margin-bottom: 10px;
      }

      .dive-card__desc {
        font-size: 13px;
        line-height: 1.6;
        color: var(--slate);
        margin-bottom: 16px;
      }

      .dive-card__tags {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
      }

      .dive-card__tag {
        padding: 5px 10px;
        background: var(--snow);
        font-size: 10px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--slate);
      }

      .dive-grid--hidden {
        display: none;
        margin-top: 24px;
      }
      .dive-grid--hidden.active {
        display: grid;
      }

      .view-more-wrapper {
        text-align: center;
        margin-top: 48px;
      }

      .link-toggle {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: none;
        border: none;
        font-family: "Manrope", sans-serif;
        font-size: 12px;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #722f37;
        cursor: pointer;
        transition: all 0.3s ease;
        padding: 0;
      }

      .link-toggle:hover {
        color: #5a252c;
        gap: 14px;
      }

      .link-toggle__arrow {
        width: 14px;
        height: 14px;
        stroke: currentColor;
        stroke-width: 2;
        fill: none;
      }

      @media (max-width: 1200px) {
        .dive-grid {
          grid-template-columns: repeat(2, 1fr);
        }
      }
      @media (max-width: 600px) {
        .dive-grid {
          grid-template-columns: 1fr;
        }
      }

      /* ════════════════════════════════════════════════════════════════
       BIODIVERSITY - Horizontal Cards
       ════════════════════════════════════════════════════════════════ */
      .bio-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 24px;
      }

      .bio-card {
        display: flex;
        background: var(--white);
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(10, 22, 40, 0.06);
        transition: transform 0.3s ease;
      }

      .bio-card:hover {
        transform: translateY(-2px);
      }

      .bio-card__image {
        width: 180px;
        flex-shrink: 0;
        overflow: hidden;
      }

      .bio-card__image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s ease;
      }

      .bio-card:hover .bio-card__image img {
        transform: scale(1.05);
      }

      .bio-card__content {
        padding: 28px;
        display: flex;
        flex-direction: column;
        justify-content: center;
      }

      .bio-card__name {
        font-family: "Cormorant Garamond", serif;
        font-size: 24px;
        font-weight: 400;
        color: var(--deep-sea);
        margin-bottom: 4px;
      }

      .bio-card__latin {
        font-size: 12px;
        font-style: italic;
        color: var(--gold-muted);
        margin-bottom: 12px;
      }

      .bio-card__desc {
        font-size: 13px;
        line-height: 1.7;
        color: var(--slate);
      }

      @media (max-width: 900px) {
        .bio-grid {
          grid-template-columns: 1fr;
        }
        .bio-card__image {
          width: 140px;
        }
      }

      @media (max-width: 600px) {
        .bio-card {
          flex-direction: column;
        }
        .bio-card__image {
          width: 100%;
          aspect-ratio: 16/9;
        }
      }

      /* Numbers & Rare Encounters */
      .stats-showcase {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0;
        margin-top: 60px;
      }

      .stats-showcase__numbers {
        background: var(--deep-sea);
        padding: 60px;
      }

      .stats-showcase__title {
        font-family: "Cormorant Garamond", serif;
        font-size: 28px;
        font-weight: 300;
        color: var(--white);
        margin-bottom: 32px;
      }

      .stats-showcase__list {
        list-style: none;
      }

      .stats-showcase__item {
        display: flex;
        align-items: baseline;
        gap: 16px;
        padding: 16px 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      }

      .stats-showcase__item:last-child {
        border-bottom: none;
      }

      .stats-showcase__number {
        font-family: "Cormorant Garamond", serif;
        font-size: 32px;
        font-weight: 300;
        color: var(--white);
        min-width: 100px;
      }

      .stats-showcase__label {
        font-size: 14px;
        color: rgba(255, 255, 255, 0.7);
      }

      /* Rare Encounters - More Visual Excitement */
      .stats-showcase__rare {
        background: linear-gradient(135deg, var(--cream) 0%, var(--white) 100%);
        padding: 60px;
        border-left: 4px solid var(--gold-muted);
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
        overflow: hidden;
      }

      .stats-showcase__rare::before {
        content: "";
        position: absolute;
        top: -50px;
        right: -50px;
        width: 200px;
        height: 200px;
        background: radial-gradient(
          circle,
          rgba(184, 168, 120, 0.15) 0%,
          transparent 70%
        );
        border-radius: 50%;
      }

      .stats-showcase__rare::after {
        content: "";
        position: absolute;
        bottom: -30px;
        right: 40%;
        width: 120px;
        height: 120px;
        background: radial-gradient(
          circle,
          rgba(149, 51, 52, 0.08) 0%,
          transparent 70%
        );
        border-radius: 50%;
      }

      .stats-showcase__rare-title {
        font-family: "Cormorant Garamond", serif;
        font-size: 28px;
        font-weight: 300;
        color: var(--deep-sea);
        margin-bottom: 24px;
        position: relative;
      }

      .stats-showcase__rare-text {
        font-size: 15px;
        line-height: 1.9;
        color: var(--slate);
        position: relative;
      }

      .stats-showcase__rare-text p {
        margin-bottom: 16px;
      }
      .stats-showcase__rare-text p:last-child {
        margin-bottom: 0;
      }
      .stats-showcase__rare-text strong {
        color: var(--deep-sea);
      }

      .stats-showcase__rare-creatures {
        display: flex;
        gap: 24px;
        margin-top: 28px;
        padding-top: 24px;
        border-top: 1px solid var(--sand);
        position: relative;
      }

      .stats-showcase__creature {
        flex: 1;
        text-align: center;
        padding: 16px 12px;
        background: var(--white);
        border-bottom: 2px solid var(--gold-muted);
      }

      .stats-showcase__creature-name {
        font-family: "Cormorant Garamond", serif;
        font-size: 18px;
        font-weight: 400;
        color: var(--deep-sea);
        margin-bottom: 4px;
      }

      .stats-showcase__creature-note {
        font-size: 11px;
        color: var(--silver);
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      @media (max-width: 900px) {
        .stats-showcase {
          grid-template-columns: 1fr;
        }
        .stats-showcase__numbers,
        .stats-showcase__rare {
          padding: 40px 24px;
        }
      }

      /* ════════════════════════════════════════════════════════════════
       SEASON CHART - With Color Coding
       ════════════════════════════════════════════════════════════════ */
      .season-wrapper {
        background: var(--white);
        border: 1px solid var(--sand);
        overflow: hidden;
      }

      .season-chart-wrapper {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
      }

      .season-chart {
        min-width: 700px;
      }

      .season-chart__table {
        width: 100%;
        border-collapse: collapse;
      }

      .season-chart__table th,
      .season-chart__table td {
        padding: 18px 16px;
        text-align: center;
        border-bottom: 1px solid var(--sand);
        font-family: "Manrope", sans-serif;
        font-size: 14px;
        font-weight: 400;
        color: var(--slate);
      }

      .season-chart__table th {
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--silver);
        background: var(--cream);
      }

      .season-chart__table th:first-child,
      .season-chart__table td:first-child {
        text-align: left;
        padding-left: 24px;
      }

      .season-chart__table tbody tr:hover {
        background: rgba(248, 246, 243, 0.5);
      }

      .season-chart__month-name {
        font-weight: 500;
        color: var(--deep-sea);
      }

      /* Color coded cells */
      .season-peak {
        background: rgba(45, 106, 79, 0.1);
      }

      .season-peak .season-status {
        color: var(--peak);
        font-weight: 500;
      }

      .season-shoulder {
        background: rgba(193, 127, 36, 0.08);
      }

      .season-shoulder .season-status {
        color: var(--shoulder);
      }

      .season-off {
        background: rgba(149, 51, 52, 0.05);
      }

      .season-off .season-status {
        color: var(--oxblood);
      }

      .season-legend {
        display: flex;
        justify-content: center;
        gap: 40px;
        padding: 20px;
        background: var(--snow);
        border-top: 1px solid var(--sand);
      }

      .season-legend__item {
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .season-legend__dot {
        width: 10px;
        height: 10px;
      }

      .season-legend__dot--peak {
        background: var(--peak);
      }
      .season-legend__dot--shoulder {
        background: var(--shoulder);
      }
      .season-legend__dot--off {
        background: transparent;
        border: 1px solid var(--sand);
      }

      .season-legend__text {
        font-size: 12px;
        font-weight: 400;
        color: var(--slate);
      }

      .two-col-text {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
      }

      .two-col-text h3 {
        font-family: "Cormorant Garamond", serif;
        font-size: 24px;
        font-weight: 400;
        color: var(--deep-sea);
        margin-bottom: 16px;
      }

      .two-col-text p {
        font-size: 15px;
        line-height: 1.9;
        color: var(--slate);
        margin-bottom: 20px;
      }

      @media (max-width: 900px) {
        .two-col-text {
          grid-template-columns: 1fr;
          gap: 40px;
        }
      }

      .offseason-note {
        background: rgba(149, 51, 52, 0.06);
        border-left: 3px solid var(--oxblood);
        padding: 24px 32px;
        margin-top: 32px;
      }

      .offseason-note__title {
        font-family: "Cormorant Garamond", serif;
        font-size: 20px;
        font-weight: 400;
        color: var(--deep-sea);
        margin-bottom: 12px;
      }

      .offseason-note p {
        font-size: 14px;
        line-height: 1.8;
        color: var(--slate);
        margin: 0;
      }

      /* ════════════════════════════════════════════════════════════════
       GETTING THERE - Two Column with Flight Table
       ════════════════════════════════════════════════════════════════ */
      .logistics-two-col {
        display: grid;
        grid-template-columns: 1fr 1.2fr;
        gap: 60px;
        margin-bottom: 40px;
      }

      .flight-table {
        background: var(--white);
        border: 1px solid var(--sand);
      }

      .flight-table__header {
        display: grid;
        grid-template-columns: 1fr 1fr;
        padding: 16px 24px;
        background: var(--cream);
        border-bottom: 1px solid var(--sand);
      }

      .flight-table__col-label {
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--oxblood);
      }

      .flight-table__row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        padding: 14px 24px;
        border-bottom: 1px solid var(--sand);
      }

      .flight-table__row:last-child {
        border-bottom: none;
      }

      .flight-table__city {
        font-size: 14px;
        font-weight: 500;
        color: var(--deep-sea);
      }

      .flight-table__time {
        font-size: 14px;
        color: var(--slate);
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .flight-table__stops {
        font-size: 11px;
        color: var(--silver);
        padding: 2px 8px;
        background: var(--snow);
        border-radius: 2px;
      }

      .logistics-content {
        display: flex;
        flex-direction: column;
        gap: 28px;
      }

      .logistics-content__block {
      }

      .logistics-content__title {
        font-family: "Cormorant Garamond", serif;
        font-size: 24px;
        font-weight: 400;
        color: var(--deep-sea);
        margin-bottom: 12px;
      }

      .logistics-content__text {
        font-size: 14px;
        line-height: 1.8;
        color: var(--slate);
      }

      .logistics-content__text + .logistics-content__text {
        margin-top: 12px;
      }

      .logistics-stats {
        display: flex;
        gap: 48px;
        padding-top: 24px;
        border-top: 1px solid var(--sand);
        margin-top: auto;
      }

      .logistics-stats__item {
        text-align: center;
      }

      .logistics-stats__value {
        font-family: "Manrope", sans-serif;
        font-size: 18px;
        font-weight: 600;
        letter-spacing: 0.02em;
        color: var(--deep-sea);
        display: block;
        margin-bottom: 6px;
      }

      .logistics-stats__label {
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--silver);
      }

      @media (max-width: 900px) {
        .logistics-two-col {
          grid-template-columns: 1fr;
          gap: 40px;
        }
        .logistics-stats {
          justify-content: center;
        }
      }

      @media (max-width: 500px) {
        .logistics-stats {
          flex-direction: column;
          gap: 20px;
        }
      }

      /* ════════════════════════════════════════════════════════════════
       INSIDER KNOWLEDGE - Gold Bar on Top
       ════════════════════════════════════════════════════════════════ */
      .insider-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
      }

      .insider-card {
        background: rgba(255, 255, 255, 0.05);
        overflow: hidden;
      }

      .insider-card__image {
        position: relative;
        aspect-ratio: 16/9;
        overflow: hidden;
      }

      .insider-card__image::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: var(--gold-muted);
        z-index: 2;
      }

      .insider-card__image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s ease;
      }

      .insider-card:hover .insider-card__image img {
        transform: scale(1.05);
      }

      .insider-card__content {
        padding: 28px;
      }

      .insider-card__title {
        font-family: "Cormorant Garamond", serif;
        font-size: 22px;
        font-weight: 400;
        color: var(--white);
        margin-bottom: 12px;
      }

      .insider-card__text {
        font-size: 14px;
        line-height: 1.8;
        color: rgba(255, 255, 255, 0.75);
      }

      @media (max-width: 1000px) {
        .insider-grid {
          grid-template-columns: 1fr;
        }
      }

      /* ════════════════════════════════════════════════════════════════
       ITINERARY CARDS - Exact Match to Itineraries Page
       ════════════════════════════════════════════════════════════════ */
      .itin-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 32px;
      }

      .itin-medium {
        display: flex;
        flex-direction: column;
        background: var(--white);
        cursor: pointer;
        overflow: hidden;
        position: relative;
        text-decoration: none;
        box-shadow:
          0 4px 6px rgba(10, 22, 40, 0.03),
          0 12px 24px rgba(10, 22, 40, 0.06);
        transition:
          box-shadow 0.4s ease,
          transform 0.4s ease;
      }

      .itin-medium:hover {
        box-shadow:
          0 8px 12px rgba(10, 22, 40, 0.04),
          0 20px 40px rgba(10, 22, 40, 0.08);
        transform: translateY(-4px);
      }

      .itin-medium::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: var(--oxblood);
        z-index: 2;
      }

      .itin-medium__image {
        aspect-ratio: 16/10;
        position: relative;
        overflow: hidden;
      }

      .itin-medium__image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      }

      .itin-medium:hover .itin-medium__image img {
        transform: scale(1.04);
      }

      .itin-medium__badge {
        position: absolute;
        top: 20px;
        left: 20px;
        background: var(--deep-sea);
        font-size: 9px;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--white);
        padding: 10px 14px;
      }

      .itin-medium__duration {
        position: absolute;
        top: 20px;
        right: 20px;
        background: var(--white);
        padding: 16px 22px;
        text-align: center;
        box-shadow: 0 4px 16px rgba(10, 22, 40, 0.12);
      }

      .itin-medium__duration-number {
        font-family: "Cormorant Garamond", serif;
        font-size: 34px;
        font-weight: 300;
        color: var(--deep-sea);
        line-height: 1;
      }

      .itin-medium__duration-label {
        font-size: 8px;
        font-weight: 500;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--deep-sea);
        opacity: 0.4;
        margin-top: 6px;
      }

      .itin-medium__content {
        padding: 32px;
        text-align: center;
      }

      .itin-medium__destination {
        font-size: 10px;
        font-weight: 500;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--oxblood);
        margin-bottom: 12px;
      }

      .itin-medium__name {
        font-family: "Cormorant Garamond", serif;
        font-size: 26px;
        font-weight: 400;
        color: var(--deep-sea);
        margin-bottom: 8px;
        line-height: 1.2;
      }

      .itin-medium__tagline {
        font-family: "Cormorant Garamond", serif;
        font-size: 15px;
        font-weight: 300;
        font-style: italic;
        color: var(--deep-sea);
        opacity: 0.5;
        margin-bottom: 16px;
      }

      .itin-medium__route {
        font-size: 12px;
        color: var(--deep-sea);
        opacity: 0.4;
        margin-bottom: 20px;
      }

      .itin-medium__cta {
        font-size: 12px;
        font-weight: 500;
        color: var(--oxblood);
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding-top: 18px;
        border-top: 1px solid var(--sand);
        transition: gap 0.3s ease;
      }

      .itin-medium:hover .itin-medium__cta {
        gap: 16px;
      }

      @media (max-width: 1000px) {
        .itin-grid {
          grid-template-columns: 1fr;
          max-width: 500px;
          margin: 0 auto;
        }
      }

      /* ════════════════════════════════════════════════════════════════
       YACHT CARDS - Exact Match to Yachts Page
       ════════════════════════════════════════════════════════════════ */
      .yacht-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
      }

      .yacht-card {
        background: var(--deep-sea);
        cursor: pointer;
        overflow: hidden;
        position: relative;
        text-decoration: none;
        color: var(--white);
        display: block;
      }

      .yacht-card__image {
        position: relative;
        aspect-ratio: 16 / 10;
        overflow: hidden;
      }

      .yacht-card__image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 1s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      }

      .yacht-card:hover .yacht-card__image img {
        transform: scale(1.03);
      }

      .yacht-card__badge {
        position: absolute;
        top: 24px;
        left: 24px;
        background: var(--white);
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--oxblood);
        padding: 10px 16px;
        z-index: 1;
      }

      .yacht-card__content {
        padding: 28px 32px 32px;
      }

      .yacht-card__name {
        font-family: "Cormorant Garamond", serif;
        font-size: 32px;
        font-weight: 300;
        margin-bottom: 8px;
        letter-spacing: 0.01em;
      }

      .yacht-card__specs {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.5);
        margin-bottom: 28px;
        letter-spacing: 0.02em;
      }

      .yacht-card__footer {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
      }

      .yacht-card__cta {
        font-size: 12px;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: gap 0.3s ease;
      }

      .yacht-card:hover .yacht-card__cta {
        gap: 12px;
      }

      .yacht-card__price {
        text-align: right;
      }

      .yacht-card__price-label {
        font-size: 10px;
        font-weight: 500;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.4);
        margin-bottom: 4px;
      }

      .yacht-card__price-value {
        font-family: "Cormorant Garamond", serif;
        font-size: 22px;
        font-weight: 400;
        letter-spacing: 0.01em;
      }

      @media (max-width: 1100px) {
        .yacht-grid {
          grid-template-columns: repeat(2, 1fr);
        }
      }
      @media (max-width: 700px) {
        .yacht-grid {
          grid-template-columns: 1fr;
        }
      }

      /* ════════════════════════════════════════════════════════════════
       DESTINATION CARDS - Exact Match to Destinations Page
       ════════════════════════════════════════════════════════════════ */
      .dest-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 28px;
      }

      .dest-card {
        position: relative;
        aspect-ratio: 16/10;
        display: block;
        text-decoration: none;
        overflow: hidden;
      }

      .dest-card__image {
        position: absolute;
        inset: 0;
      }

      .dest-card__image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 1.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      }

      .dest-card:hover .dest-card__image img {
        transform: scale(1.06);
      }

      .dest-card__overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
          to top,
          rgba(10, 22, 40, 0.9) 0%,
          rgba(10, 22, 40, 0.4) 40%,
