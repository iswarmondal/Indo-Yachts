      /* ════════════════════════════════════════════════════════════════
       DESTINATION CARDS — Exact Match to Destinations Page
       ════════════════════════════════════════════════════════════════ */
      .dest-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 28px;
      }

      .dest-card {
        position: relative;
        aspect-ratio: 16/10;
        display: block;
