      }

      .dest-card__content {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 28px;
        z-index: 2;
      }

      .dest-card__region {
        font-size: 9px;
        font-weight: 600;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--gold-muted);
        margin-bottom: 10px;
      }

      .dest-card__title {
        font-family: "Cormorant Garamond", serif;
        font-size: 30px;
        font-weight: 300;
        color: var(--white);
        line-height: 1.15;
