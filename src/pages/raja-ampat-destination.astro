---
import Header from "../components/Header.astro";
import BaseHead from "../components/BaseHead.astro";
import SmoothScroll from "../components/SmoothScroll.astro";
import LuxuryInteractions from "../components/LuxuryInteractions.astro";
import { Image } from "astro:assets";
import heroPhinisi from "../assets/images/hero-phinisi.jpg";
import wayagAerial from "../assets/images/wayag-aerial.jpg";
import coralReef from "../assets/images/coral-reef.jpg";
import mantaRays from "../assets/images/manta-rays.jpg";
import wayagSunset from "../assets/images/wayag-sunset.jpg";
import misoolLagoon from "../assets/images/misool-lagoon.jpg";
import caveDiving from "../assets/images/cave-diving.jpg";
import beachTurquoise from "../assets/images/beach-turquoise.jpg";
import softCoralMangrove from "../assets/images/soft-coral-mangrove.jpg";
import karstTurquoise from "../assets/images/karst-turquoise.jpg";
import splitShot from "../assets/images/split-shot.jpg";
import duniaBaru from "../assets/images/dunia-baru.jpg";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="Raja Ampat Yacht Charters — Indo Yachts"
      description="Explore Raja Ampat by private phinisi yacht—legendary dive sites, manta encounters, and bespoke charters across the world's most biodiverse marine archipelago."
    />
    <style>
      :root {
        --oxblood: #6b3a3a;
        --oxblood-deep: #543030;
        --oxblood-light: #7d4545;
        --deep-sea: #0c1829;
        --deep-sea-light: #152238;
        --white: #ffffff;
        --snow: #faf9f7;
        --cream: #f5f2ec;
        --ivory: #faf8f4;
        --sand: #e4dfd6;
        --linen: #d9d3c8;
        --charcoal: #1c1c1c;
        --slate: #5a5650;
        --silver: #8a857c;
        --gold-muted: #9a8b62;
        --gold-light: #c4b896;
        --gold-faint: rgba(154, 139, 98, 0.12);
        --peak: #3d5c4a;
        --shoulder: #9a7b4f;
        --border-subtle: rgba(12, 24, 41, 0.08);
        --border-gold: rgba(154, 139, 98, 0.28);
        --shadow-soft: 0 2px 24px rgba(12, 24, 41, 0.04);
        --shadow-lift: 0 8px 32px rgba(12, 24, 41, 0.06);
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      html {
        font-size: 16px;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      body {
        font-family: "Manrope", sans-serif;
        font-weight: 300;
        background: var(--ivory);
        color: var(--charcoal);
        letter-spacing: 0.01em;
      }

      ::selection {
        background: var(--gold-faint);
        color: var(--deep-sea);
      }

      /* ════════════════════════════════════════════════════════════════
       HERO - CONCEPT B EDITORIAL FRAME
       ════════════════════════════════════════════════════════════════ */
      .hero {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        background: var(--ivory);
      }

      .hero__frame {
        flex: 1;
        position: relative;
        margin: 0;
        overflow: hidden;
        min-height: 100vh;
      }

      .hero__frame::after {
        content: "";
        position: absolute;
        inset: 20px;
        border: 1px solid rgba(196, 184, 150, 0.22);
        pointer-events: none;
        z-index: 3;
      }

      .hero__image {
        position: absolute;
        inset: 0;
        will-change: transform;
      }

      .hero__image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transform: scale(1.06);
      }

      @keyframes heroReveal {
        from {
          opacity: 0;
          transform: translate3d(0, 22px, 0);
        }
        to {
          opacity: 1;
          transform: translate3d(0, 0, 0);
        }
      }

      @media (prefers-reduced-motion: no-preference) {
        .hero__eyebrow,
        .hero__title,
        .hero__tagline,
        .hero__scroll {
          opacity: 0;
          animation: heroReveal 1.15s cubic-bezier(0.22, 1, 0.36, 1) forwards;
        }

        .hero__eyebrow {
          animation-delay: 0.25s;
        }

        .hero__title {
          animation-delay: 0.42s;
        }

        .hero__tagline {
          animation-delay: 0.58s;
        }

        .hero__scroll {
          animation-delay: 0.75s;
        }

        .info-footer__item {
          opacity: 0;
          animation: heroReveal 1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
        }

        .info-footer__item:nth-child(1) {
          animation-delay: 0.85s;
        }
        .info-footer__item:nth-child(2) {
          animation-delay: 0.95s;
        }
        .info-footer__item:nth-child(3) {
          animation-delay: 1.05s;
        }
        .info-footer__item:nth-child(4) {
          animation-delay: 1.15s;
        }
      }

      .hero__overlay {
        position: absolute;
        inset: 0;
        background:
          linear-gradient(
            to bottom,
            rgba(12, 24, 41, 0.45) 0%,
            rgba(12, 24, 41, 0.12) 18%,
            transparent 32%
          ),
          linear-gradient(
            to top,
            rgba(12, 24, 41, 0.82) 0%,
            rgba(12, 24, 41, 0.28) 45%,
            transparent 72%
          );
      }

      .hero__content {
        position: absolute;
        bottom: 60px;
        left: 8%;
        right: 8%;
        z-index: 2;
        will-change: opacity, transform;
      }

      .hero__eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 16px;
      }

      .hero__eyebrow-line {
        width: 40px;
        height: 1px;
        background: var(--gold-muted);
      }

      .hero__eyebrow-text {
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: var(--gold-muted);
      }

      .hero__title {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(52px, 8vw, 92px);
        font-weight: 300;
        font-style: italic;
        color: var(--white);
        letter-spacing: 0.04em;
        line-height: 0.92;
        margin-bottom: 20px;
      }

      .hero__tagline {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(18px, 2vw, 22px);
        font-weight: 300;
        font-style: italic;
        color: rgba(255, 255, 255, 0.85);
      }

      .hero__scroll {
        position: absolute;
        bottom: 60px;
        right: 8%;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
      }

      .hero__scroll-text {
        font-size: 10px;
        font-weight: 500;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.5);
      }

      .hero__scroll-line {
        width: 1px;
        height: 40px;
        background: linear-gradient(
          to bottom,
          rgba(255, 255, 255, 0.4),
          transparent
        );
        animation: scrollPulse 2s ease-in-out infinite;
      }

      @keyframes scrollPulse {
        0%,
        100% {
          opacity: 1;
          transform: scaleY(1);
        }
        50% {
          opacity: 0.5;
          transform: scaleY(0.8);
        }
      }

      @media (max-width: 900px) {
        .hero__frame {
          margin: 0;
        }
        .hero__frame::after {
          inset: 12px;
        }
        .hero__content {
          left: 24px;
          right: 24px;
          bottom: 40px;
        }
        .hero__scroll {
          display: none;
        }
      }

      /* ════════════════════════════════════════════════════════════════
       INFO FOOTER - TRUST BAR (LIGHT STYLE)
       ════════════════════════════════════════════════════════════════ */
      .info-footer {
        padding: 48px 8%;
        background: var(--cream);
        border-top: 1px solid var(--sand);
      }

      .info-footer__inner {
        display: flex;
        justify-content: center;
        gap: 0;
        flex-wrap: wrap;
        max-width: 1100px;
        margin: 0 auto;
      }

      .info-footer__item {
        text-align: center;
        flex: 1;
        min-width: 160px;
        padding: 0 40px;
        position: relative;
      }

      .info-footer__item:not(:last-child)::after {
        content: "";
        position: absolute;
        right: 0;
        top: 50%;
        transform: translateY(-50%);
        width: 1px;
        height: 36px;
        background: var(--linen);
      }

      .info-footer__value {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(22px, 2.5vw, 28px);
        font-weight: 300;
        color: var(--deep-sea);
        margin-bottom: 10px;
        letter-spacing: 0.02em;
      }

      .info-footer__label {
        font-size: 9px;
        font-weight: 500;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--gold-muted);
      }

      @media (max-width: 900px) {
        .info-footer {
          padding: 36px 24px;
        }
        .info-footer__inner {
          gap: 28px 0;
        }
        .info-footer__item {
          flex: 1 1 45%;
          padding: 0 16px;
        }
        .info-footer__item::after {
          display: none;
        }
      }

      /* ════════════════════════════════════════════════════════════════
       SECTIONS
       ════════════════════════════════════════════════════════════════ */
      .section {
        padding: 120px 48px;
      }
      .section--white {
        background: var(--ivory);
      }
      .section--snow {
        background: var(--snow);
      }
      .section--cream {
        background: var(--cream);
      }
      .section--deep {
        background: var(--deep-sea);
        color: var(--white);
      }
      .section__inner {
        max-width: 1400px;
        margin: 0 auto;
      }

      @media (max-width: 768px) {
        .section {
          padding: 60px 24px;
        }
      }

      /* Section Headers */
      .section-header {
        text-align: center;
        margin-bottom: 60px;
      }

      .section-header__label {
        font-size: 9px;
        font-weight: 500;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        color: var(--gold-muted);
        margin-bottom: 20px;
      }

      .section-header__title {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(34px, 5vw, 46px);
        font-weight: 300;
        color: var(--deep-sea);
        line-height: 1.12;
        margin-bottom: 24px;
        letter-spacing: 0.01em;
      }

      .section-header__subtitle {
        font-size: 15px;
        font-weight: 300;
        line-height: 2;
        color: var(--slate);
        max-width: 640px;
        margin: 0 auto;
      }

      .section--deep .section-header__label {
        color: var(--gold-muted);
      }
      .section--deep .section-header__title {
        color: var(--white);
      }
      .section--deep .section-header__subtitle {
        color: rgba(255, 255, 255, 0.7);
      }

      /* ════════════════════════════════════════════════════════════════
       OVERVIEW — EDITORIAL INTRO
       ════════════════════════════════════════════════════════════════ */
      .overview-section {
        background: var(--cream);
        position: relative;
        overflow: hidden;
      }

      .overview-section::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(
          90deg,
          transparent,
          var(--sand) 20%,
          var(--sand) 80%,
          transparent
        );
      }

      .overview {
        display: grid;
        grid-template-columns: 1.05fr 0.95fr;
        gap: 72px;
        align-items: start;
      }

      .overview__label {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        font-size: 9px;
        font-weight: 500;
        letter-spacing: 0.24em;
        text-transform: uppercase;
        color: var(--gold-muted);
        margin-bottom: 24px;
      }

      .overview__label::before {
        content: "";
        width: 48px;
        height: 1px;
        background: var(--gold-muted);
      }

      .overview__text h2 {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(34px, 4vw, 44px);
        font-weight: 300;
        color: var(--deep-sea);
        margin-bottom: 24px;
        line-height: 1.15;
        max-width: 14ch;
      }

      .overview__lead {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(19px, 2.2vw, 22px);
        font-weight: 300;
        font-style: italic;
        line-height: 1.65;
        color: var(--slate);
        margin-bottom: 28px;
        padding-left: 20px;
        border-left: 1px solid var(--gold-muted);
      }

      .overview__text p {
        font-size: 15px;
        line-height: 1.95;
        color: var(--slate);
        margin-bottom: 18px;
      }

      .overview__text p strong {
        color: var(--deep-sea);
        font-weight: 500;
      }

      .overview__stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0;
        margin-top: 40px;
        border: 1px solid var(--sand);
      }

      .overview__stat {
        background: var(--ivory);
        padding: 28px 20px;
        text-align: center;
        border-right: 1px solid var(--sand);
      }

      .overview__stat:last-child {
        border-right: none;
      }

      .overview__stat-value {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(28px, 3vw, 36px);
        font-weight: 300;
        color: var(--deep-sea);
        line-height: 1;
        margin-bottom: 8px;
      }

      .overview__stat-label {
        font-size: 9px;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--silver);
        line-height: 1.4;
      }

      .overview__visual {
        position: relative;
        padding-top: 4px;
      }

      .overview__image-frame {
        position: relative;
        overflow: hidden;
        aspect-ratio: 3 / 2;
        box-shadow: var(--shadow-soft);
        border: 1px solid var(--sand);
      }

      .overview__image-frame img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center 35%;
        display: block;
      }

      .overview__image-accent {
        position: absolute;
        bottom: -12px;
        left: -12px;
        width: 72px;
        height: 72px;
        border: 1px solid var(--gold-muted);
        opacity: 0.4;
        pointer-events: none;
        z-index: -1;
      }

      .overview__image-caption {
        font-family: "Cormorant Garamond", serif;
        font-size: 14px;
        font-weight: 300;
        font-style: italic;
        color: var(--silver);
        margin-top: 20px;
        line-height: 1.5;
        text-align: right;
        padding-right: 4px;
      }

      @media (max-width: 1000px) {
        .overview {
          grid-template-columns: 1fr;
          gap: 48px;
        }

        .overview__text h2 {
          max-width: none;
        }

        .overview__visual {
          order: -1;
          max-width: 100%;
          padding-top: 0;
        }

        .overview__image-frame {
          aspect-ratio: 16 / 10;
        }

        .overview__image-accent {
          display: none;
        }

        .overview__image-caption {
          text-align: left;
        }
      }

      @media (max-width: 600px) {
        .overview__stats {
          grid-template-columns: 1fr;
        }
      }

      /* Featured Quote - Full Width */
      .featured-quote {
        background: var(--deep-sea);
        padding: 120px 48px;
        text-align: center;
        position: relative;
      }

      .featured-quote::before {
        content: '"';
        position: absolute;
        top: 48px;
        left: 50%;
        transform: translateX(-50%);
        font-family: "Cormorant Garamond", serif;
        font-size: 140px;
        font-weight: 300;
        color: var(--gold-muted);
        opacity: 0.15;
        line-height: 1;
      }

      .featured-quote::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 48px;
        height: 1px;
        background: var(--gold-muted);
        opacity: 0.35;
      }

      .featured-quote__inner {
        max-width: 900px;
        margin: 0 auto;
        position: relative;
        z-index: 1;
      }

      .featured-quote__text {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(28px, 4vw, 42px);
        font-weight: 300;
        font-style: italic;
        color: var(--white);
        line-height: 1.45;
        margin-bottom: 28px;
        letter-spacing: 0.01em;
      }

      .featured-quote__attribution {
        font-size: 12px;
        font-weight: 400;
        color: var(--gold-light);
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      /* Two Column with Image */
      .two-col-with-image {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        align-items: start;
      }

      .two-col-with-image__text h3 {
        font-family: "Cormorant Garamond", serif;
        font-size: 36px;
        font-weight: 300;
        color: var(--deep-sea);
        margin-bottom: 24px;
        line-height: 1.2;
      }

      .two-col-with-image__text p {
        font-size: 15px;
        line-height: 1.9;
        color: var(--slate);
        margin-bottom: 16px;
      }

      .two-col-with-image__text p strong {
        color: var(--deep-sea);
      }

      .two-col-with-image__image img {
        width: 100%;
        height: auto;
        border: 1px solid var(--sand);
      }

      @media (max-width: 900px) {
        .two-col-with-image {
          grid-template-columns: 1fr;
          gap: 40px;
        }
      }

      /* Highlight Box */
      .highlight-box {
        background: var(--cream);
        padding: 32px;
        margin: 32px 0;
        border-left: 1px solid var(--gold-muted);
      }

      .highlight-box__title {
        font-family: "Cormorant Garamond", serif;
        font-size: 20px;
        font-weight: 400;
        color: var(--deep-sea);
        margin-bottom: 12px;
      }

      .highlight-box p {
        font-size: 14px;
        line-height: 1.8;
        color: var(--slate);
        margin: 0;
      }

      /* Experience Grid */
      .experience-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        margin-top: 60px;
      }

      .experience-card {
        background: var(--snow);
        padding: 40px;
      }

      .experience-card__title {
        font-family: "Cormorant Garamond", serif;
        font-size: 24px;
        font-weight: 400;
        color: var(--deep-sea);
        margin-bottom: 16px;
      }

      .experience-card p {
        font-size: 14px;
        line-height: 1.8;
        color: var(--slate);
      }

      @media (max-width: 768px) {
        .experience-grid {
          grid-template-columns: 1fr;
          gap: 24px;
        }
      }

      /* Beyond Underwater - Full Width Feature */
      .beyond-section {
        background: var(--cream);
        padding: 100px 48px;
        position: relative;
      }

      .beyond-section__inner {
        max-width: 1400px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        align-items: center;
      }

      .beyond-section__content {
        position: relative;
      }

      .beyond-section__label {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        font-size: 9px;
        font-weight: 500;
        letter-spacing: 0.24em;
        text-transform: uppercase;
        color: var(--gold-muted);
        margin-bottom: 24px;
      }

      .beyond-section__label::before {
        content: "";
        width: 48px;
        height: 1px;
        background: var(--gold-muted);
      }

      .beyond-section__content h2 {
        font-family: "Cormorant Garamond", serif;
        font-size: 36px;
        font-weight: 300;
        color: var(--deep-sea);
        margin-bottom: 24px;
        line-height: 1.2;
      }

      .beyond-section__content p {
        font-size: 15px;
        line-height: 1.9;
        color: var(--slate);
        margin-bottom: 20px;
      }

      .beyond-section__content p strong {
        color: var(--deep-sea);
      }

      .beyond-section__highlights {
        display: flex;
        gap: 32px;
        margin-top: 32px;
        padding-top: 28px;
        border-top: 1px solid var(--sand);
      }

      .beyond-section__highlight {
        flex: 1;
      }

      .beyond-section__highlight-title {
        font-family: "Cormorant Garamond", serif;
        font-size: 18px;
        font-weight: 400;
        color: var(--deep-sea);
        margin-bottom: 6px;
      }

      .beyond-section__highlight-text {
        font-size: 13px;
        color: var(--silver);
        line-height: 1.6;
      }

      .beyond-section__image {
        position: relative;
      }

      .beyond-section__image img {
        width: 100%;
        height: auto;
      }

      .beyond-section__image-accent {
        position: absolute;
        bottom: -20px;
        left: -20px;
        width: 120px;
        height: 120px;
        border: 1px solid var(--gold-muted);
        opacity: 0.4;
        z-index: -1;
      }

      @media (max-width: 900px) {
        .beyond-section {
          padding: 60px 24px;
        }
        .beyond-section__inner {
          grid-template-columns: 1fr;
          gap: 40px;
        }
        .beyond-section__highlights {
          flex-direction: column;
          gap: 20px;
        }
        .beyond-section__image-accent {
          display: none;
        }
      }

      /* Indo Yachts Experience - Left-Aligned Bounded (V1) */
      .expertise-hero {
        position: relative;
        min-height: 600px;
        overflow: hidden;
      }

      .expertise-hero__image {
        position: absolute;
        inset: 0;
      }

      .expertise-hero__image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .expertise-hero__overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
          to right,
          rgba(10, 22, 40, 0.92) 0%,
          rgba(10, 22, 40, 0.85) 35%,
          rgba(10, 22, 40, 0.5) 60%,
          rgba(10, 22, 40, 0.2) 100%
        );
      }

      .expertise-hero__inner {
        position: relative;
        z-index: 2;
        max-width: 1400px;
        margin: 0 auto;
        padding: 100px 48px;
        display: flex;
        align-items: center;
        min-height: 600px;
      }

      .expertise-hero__content {
        max-width: 580px;
      }

      .expertise-hero__label {
        display: inline-flex;
        align-items: center;
        gap: 16px;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--gold-muted);
        margin-bottom: 24px;
      }

      .expertise-hero__label::after {
        content: "";
        width: 60px;
        height: 1px;
        background: var(--gold-muted);
        opacity: 0.4;
      }

      .expertise-hero__title {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(40px, 5vw, 56px);
        font-weight: 300;
        color: var(--white);
        line-height: 1.1;
        margin-bottom: 28px;
      }

      .expertise-hero__text {
        font-size: 16px;
        line-height: 1.9;
        color: rgba(255, 255, 255, 0.8);
        margin-bottom: 16px;
      }

      .expertise-hero__stats {
        display: flex;
        gap: 48px;
        margin-top: 40px;
        padding-top: 32px;
        border-top: 1px solid rgba(255, 255, 255, 0.15);
      }

      .expertise-hero__stat-value {
        font-family: "Cormorant Garamond", serif;
        font-size: 40px;
        font-weight: 300;
        color: var(--white);
        line-height: 1;
        margin-bottom: 6px;
      }

      .expertise-hero__stat-label {
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--gold-muted);
      }

      @media (max-width: 900px) {
        .expertise-hero {
          min-height: 650px;
        }
        .expertise-hero__overlay {
          background: linear-gradient(
            to top,
            rgba(10, 22, 40, 0.95) 0%,
            rgba(10, 22, 40, 0.8) 50%,
            rgba(10, 22, 40, 0.5) 100%
          );
        }
        .expertise-hero__inner {
          padding: 60px 24px;
          align-items: flex-end;
        }
        .expertise-hero__content {
          max-width: 100%;
        }
        .expertise-hero__stats {
          flex-wrap: wrap;
          gap: 32px;
        }
      }

      /* ════════════════════════════════════════════════════════════════
       REGIONS — THE FOUR KINGDOMS
       ════════════════════════════════════════════════════════════════ */
      .region-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
      }

      .region-card {
        background: var(--ivory);
        overflow: hidden;
        border: 1px solid var(--sand);
        transition: border-color 0.4s ease;
      }

      .region-card:hover {
        border-color: var(--border-gold);
      }

      .region-card__image {
        aspect-ratio: 16/10;
        overflow: hidden;
      }

      .region-card__image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 1s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      }

      .region-card:hover .region-card__image img {
        transform: scale(1.03);
      }

      .region-card__content {
        padding: 32px;
      }

      .region-card__label {
        font-size: 9px;
        font-weight: 500;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--gold-muted);
        margin-bottom: 14px;
      }

      .region-card__title {
        font-family: "Cormorant Garamond", serif;
        font-size: 28px;
        font-weight: 300;
        color: var(--deep-sea);
        margin-bottom: 16px;
      }

      .region-card__desc {
        font-size: 14px;
        line-height: 1.8;
        color: var(--slate);
        margin-bottom: 20px;
      }

      .region-card__highlights {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      .region-card__highlight {
        padding: 6px 14px;
        background: transparent;
        border: 1px solid var(--sand);
        font-size: 10px;
        font-weight: 400;
        letter-spacing: 0.06em;
        color: var(--slate);
      }

      @media (max-width: 1100px) {
        .region-grid {
          grid-template-columns: 1fr;
        }
      }

      /* ════════════════════════════════════════════════════════════════
       DIVE SITES
       ════════════════════════════════════════════════════════════════ */
      .dive-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 24px;
      }

      .dive-card {
        background: var(--ivory);
        overflow: hidden;
        position: relative;
        border: 1px solid var(--sand);
        transition:
          border-color 0.45s ease,
          box-shadow 0.45s ease;
      }

      .dive-card::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: var(--gold-muted);
        z-index: 2;
        opacity: 0.5;
      }

      .dive-card:hover {
        border-color: var(--border-gold);
        box-shadow: var(--shadow-soft);
      }

      .dive-card__image {
        aspect-ratio: 4/3;
        overflow: hidden;
      }

      .dive-card__image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 1.1s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      }

      .dive-card:hover .dive-card__image img {
        transform: scale(1.04);
      }

      .dive-card__content {
        padding: 28px 28px 32px;
        border-top: 1px solid rgba(10, 22, 40, 0.05);
      }

      .dive-card__region {
        display: block;
        font-size: 9px;
        font-weight: 500;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--gold-muted);
        margin-bottom: 14px;
        padding-bottom: 12px;
        border-bottom: 1px solid var(--sand);
      }

      .dive-card__title {
        font-family: "Cormorant Garamond", serif;
        font-size: 24px;
        font-weight: 300;
        color: var(--deep-sea);
        margin-bottom: 12px;
        line-height: 1.2;
      }

      .dive-card__desc {
        font-size: 13px;
        line-height: 1.75;
        color: var(--slate);
        margin-bottom: 20px;
      }

      .dive-card__tags {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        padding-top: 4px;
      }

      .dive-card__tag {
        padding: 5px 12px;
        background: transparent;
        border: 1px solid var(--border-gold);
        font-size: 8px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--gold-muted);
        transition:
          border-color 0.3s ease,
          color 0.3s ease;
      }

      .dive-card__tag:nth-child(even) {
        border-color: var(--sand);
        color: var(--slate);
      }

      .dive-card:hover .dive-card__tag {
        border-color: var(--gold-muted);
      }

      .dive-grid--hidden {
        display: none;
        margin-top: 24px;
      }
      .dive-grid--hidden.active {
        display: grid;
      }

      .view-more-wrapper {
        text-align: center;
        margin-top: 48px;
      }

      .link-toggle {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: none;
        border: none;
        font-family: "Manrope", sans-serif;
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--deep-sea);
        cursor: pointer;
        transition: all 0.3s ease;
        padding: 0;
      }

      .link-toggle:hover {
        color: var(--gold-muted);
        gap: 14px;
      }

      .link-toggle__arrow {
        width: 14px;
        height: 14px;
        stroke: currentColor;
        stroke-width: 2;
        fill: none;
      }

      @media (max-width: 1200px) {
        .dive-grid {
          grid-template-columns: repeat(2, 1fr);
        }
      }
      @media (max-width: 600px) {
        .dive-grid {
          grid-template-columns: 1fr;
        }
      }

      /* ════════════════════════════════════════════════════════════════
       BIODIVERSITY — Editorial species list
       ════════════════════════════════════════════════════════════════ */
      .bio-grid {
        display: flex;
        flex-direction: column;
        gap: 0;
        max-width: 1120px;
        margin: 0 auto;
        counter-reset: bio-index;
      }

      .bio-card {
        counter-increment: bio-index;
        display: grid;
        grid-template-columns: minmax(260px, 0.92fr) minmax(0, 1.08fr);
        gap: 56px;
        align-items: center;
        padding: 52px 0;
        border-bottom: 1px solid var(--sand);
        background: transparent;
        position: relative;
        transition: border-color 0.4s ease;
      }

      .bio-card:first-child {
        padding-top: 8px;
      }

      .bio-card:last-child {
        border-bottom: none;
        padding-bottom: 0;
      }

      .bio-card::before {
        content: counter(bio-index, decimal-leading-zero);
        position: absolute;
        top: 52px;
        left: 0;
        font-family: "Cormorant Garamond", serif;
        font-size: 12px;
        font-weight: 400;
        letter-spacing: 0.22em;
        color: var(--gold-muted);
        opacity: 0.55;
      }

      .bio-card:nth-child(even) {
        grid-template-columns: minmax(0, 1.08fr) minmax(260px, 0.92fr);
      }

      .bio-card:nth-child(even)::before {
        left: auto;
        right: 0;
      }

      .bio-card:nth-child(even) .bio-card__image {
        order: 2;
      }

      .bio-card:nth-child(even) .bio-card__content {
        order: 1;
        text-align: right;
        align-items: flex-end;
      }

      .bio-card:hover {
        border-color: var(--linen);
      }

      .bio-card__image {
        width: 100%;
        aspect-ratio: 5 / 4;
        flex-shrink: 0;
        overflow: hidden;
        position: relative;
        border: 1px solid var(--sand);
        background: var(--ivory);
      }

      .bio-card__image::after {
        content: "";
        position: absolute;
        bottom: -10px;
        right: -10px;
        width: 56px;
        height: 56px;
        border: 1px solid var(--gold-muted);
        opacity: 0.28;
        pointer-events: none;
        z-index: 1;
        transition: opacity 0.4s ease;
      }

      .bio-card:nth-child(even) .bio-card__image::after {
        right: auto;
        left: -10px;
      }

      .bio-card:hover .bio-card__image::after {
        opacity: 0.45;
      }

      .bio-card__image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 1.1s cubic-bezier(0.22, 1, 0.36, 1);
      }

      .bio-card:hover .bio-card__image img {
        transform: scale(1.04);
      }

      .bio-card__content {
        padding: 8px 0 8px 36px;
        display: flex;
        flex-direction: column;
        justify-content: center;
      }

      .bio-card:nth-child(even) .bio-card__content {
        padding: 8px 36px 8px 0;
      }

      .bio-card__name {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(26px, 2.8vw, 34px);
        font-weight: 300;
        color: var(--deep-sea);
        margin-bottom: 8px;
        line-height: 1.15;
        letter-spacing: 0.01em;
      }

      .bio-card__name::after {
        content: "";
        display: block;
        width: 36px;
        height: 1px;
        margin-top: 14px;
        background: var(--gold-muted);
        opacity: 0.4;
      }

      .bio-card:nth-child(even) .bio-card__name::after {
        margin-left: auto;
      }

      .bio-card__latin {
        font-family: "Cormorant Garamond", serif;
        font-size: 14px;
        font-style: italic;
        font-weight: 300;
        color: var(--gold-muted);
        margin-bottom: 18px;
        letter-spacing: 0.02em;
      }

      .bio-card__desc {
        font-size: 14px;
        font-weight: 300;
        line-height: 1.85;
        color: var(--slate);
        max-width: 38ch;
      }

      .bio-card:first-child {
        grid-template-columns: minmax(300px, 1fr) minmax(0, 1fr);
        gap: 64px;
        padding-bottom: 60px;
      }

      .bio-card:first-child .bio-card__image {
        aspect-ratio: 16 / 11;
      }

      .bio-card:first-child .bio-card__name {
        font-size: clamp(30px, 3.2vw, 40px);
      }

      @media (max-width: 900px) {
        .bio-card,
        .bio-card:nth-child(even),
        .bio-card:first-child {
          grid-template-columns: 1fr;
          gap: 28px;
          padding: 40px 0;
        }

        .bio-card::before,
        .bio-card:nth-child(even)::before {
          position: static;
          display: block;
          margin-bottom: 4px;
          opacity: 0.7;
        }

        .bio-card:nth-child(even) .bio-card__image,
        .bio-card:nth-child(even) .bio-card__content {
          order: unset;
          text-align: left;
          align-items: flex-start;
        }

        .bio-card__content,
        .bio-card:nth-child(even) .bio-card__content {
          padding: 0;
        }

        .bio-card__image::after,
        .bio-card:nth-child(even) .bio-card__image::after {
          display: none;
        }

        .bio-card__desc {
          max-width: none;
        }
      }

      /* Numbers & Rare Encounters */
      .stats-showcase {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0;
        margin-top: 60px;
      }

      .stats-showcase__numbers {
        background: var(--deep-sea);
        padding: 60px;
      }

      .stats-showcase__title {
        font-family: "Cormorant Garamond", serif;
        font-size: 28px;
        font-weight: 300;
        color: var(--white);
        margin-bottom: 32px;
      }

      .stats-showcase__list {
        list-style: none;
      }

      .stats-showcase__item {
        display: flex;
        align-items: baseline;
        gap: 16px;
        padding: 16px 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      }

      .stats-showcase__item:last-child {
        border-bottom: none;
      }

      .stats-showcase__number {
        font-family: "Cormorant Garamond", serif;
        font-size: 32px;
        font-weight: 300;
        color: var(--white);
        min-width: 100px;
      }

      .stats-showcase__label {
        font-size: 14px;
        color: rgba(255, 255, 255, 0.7);
      }

      /* Rare Encounters - More Visual Excitement */
      .stats-showcase__rare {
        background: var(--ivory);
        padding: 60px;
        border-left: 1px solid var(--gold-muted);
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
        overflow: hidden;
      }

      .stats-showcase__rare::before,
      .stats-showcase__rare::after {
        display: none;
      }

      .stats-showcase__rare-title {
        font-family: "Cormorant Garamond", serif;
        font-size: 28px;
        font-weight: 300;
        color: var(--deep-sea);
        margin-bottom: 24px;
        position: relative;
      }

      .stats-showcase__rare-text {
        font-size: 15px;
        line-height: 1.9;
        color: var(--slate);
        position: relative;
      }

      .stats-showcase__rare-text p {
        margin-bottom: 16px;
      }
      .stats-showcase__rare-text p:last-child {
        margin-bottom: 0;
      }
      .stats-showcase__rare-text strong {
        color: var(--deep-sea);
      }

      .stats-showcase__rare-creatures {
        display: flex;
        gap: 24px;
        margin-top: 28px;
        padding-top: 24px;
        border-top: 1px solid var(--sand);
        position: relative;
      }

      .stats-showcase__creature {
        flex: 1;
        text-align: center;
        padding: 16px 12px;
        background: var(--cream);
        border-bottom: 1px solid var(--gold-muted);
      }

      .stats-showcase__creature-name {
        font-family: "Cormorant Garamond", serif;
        font-size: 18px;
        font-weight: 400;
        color: var(--deep-sea);
        margin-bottom: 4px;
      }

      .stats-showcase__creature-note {
        font-size: 11px;
        color: var(--silver);
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      @media (max-width: 900px) {
        .stats-showcase {
          grid-template-columns: 1fr;
        }
        .stats-showcase__numbers,
        .stats-showcase__rare {
          padding: 40px 24px;
        }
      }

      /* ════════════════════════════════════════════════════════════════
       SEASON CHART — With Color Coding
       ════════════════════════════════════════════════════════════════ */
      .season-wrapper {
        background: var(--white);
        border: 1px solid var(--sand);
        overflow: hidden;
      }

      .season-chart-wrapper {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
      }

      .season-chart {
        min-width: 700px;
      }

      .season-chart__table {
        width: 100%;
        border-collapse: collapse;
      }

      .season-chart__table th,
      .season-chart__table td {
        padding: 18px 16px;
        text-align: center;
        border-bottom: 1px solid var(--sand);
        font-family: "Manrope", sans-serif;
        font-size: 14px;
        font-weight: 400;
        color: var(--slate);
      }

      .season-chart__table th {
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--silver);
        background: var(--cream);
      }

      .season-chart__table th:first-child,
      .season-chart__table td:first-child {
        text-align: left;
        padding-left: 24px;
      }

      .season-chart__table tbody tr:hover {
        background: rgba(248, 246, 243, 0.5);
      }

      .season-chart__month-name {
        font-weight: 500;
        color: var(--deep-sea);
      }

      /* Color coded cells */
      .season-peak {
        background: rgba(61, 92, 74, 0.06);
      }

      .season-peak .season-status {
        color: var(--peak);
        font-weight: 500;
      }

      .season-shoulder {
        background: rgba(154, 123, 79, 0.06);
      }

      .season-shoulder .season-status {
        color: var(--shoulder);
      }

      .season-off {
        background: rgba(107, 58, 58, 0.04);
      }

      .season-off .season-status {
        color: var(--oxblood);
      }

      .season-legend {
        display: flex;
        justify-content: center;
        gap: 40px;
        padding: 20px;
        background: var(--snow);
        border-top: 1px solid var(--sand);
      }

      .season-legend__item {
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .season-legend__dot {
        width: 10px;
        height: 10px;
      }

      .season-legend__dot--peak {
        background: var(--peak);
      }
      .season-legend__dot--shoulder {
        background: var(--shoulder);
      }
      .season-legend__dot--off {
        background: transparent;
        border: 1px solid var(--sand);
      }

      .season-legend__text {
        font-size: 12px;
        font-weight: 400;
        color: var(--slate);
      }

      .two-col-text {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
      }

      .two-col-text h3 {
        font-family: "Cormorant Garamond", serif;
        font-size: 24px;
        font-weight: 400;
        color: var(--deep-sea);
        margin-bottom: 16px;
      }

      .two-col-text p {
        font-size: 15px;
        line-height: 1.9;
        color: var(--slate);
        margin-bottom: 20px;
      }

      @media (max-width: 900px) {
        .two-col-text {
          grid-template-columns: 1fr;
          gap: 40px;
        }
        .two-col-text > div {
          min-width: 0;
        }
      }

      .offseason-note {
        background: var(--cream);
        border-left: 1px solid var(--gold-muted);
        padding: 28px 32px;
        margin-top: 32px;
      }

      .offseason-note__title {
        font-family: "Cormorant Garamond", serif;
        font-size: 20px;
        font-weight: 400;
        color: var(--deep-sea);
        margin-bottom: 12px;
      }

      .offseason-note p {
        font-size: 14px;
        line-height: 1.8;
        color: var(--slate);
        margin: 0;
      }

      /* ════════════════════════════════════════════════════════════════
       GETTING THERE - Two Column with Flight Table
       ════════════════════════════════════════════════════════════════ */
      .logistics-two-col {
        display: grid;
        grid-template-columns: 1fr 1.2fr;
        gap: 60px;
        margin-bottom: 40px;
      }

      .flight-table {
        background: var(--white);
        border: 1px solid var(--sand);
      }

      .flight-table__header {
        display: grid;
        grid-template-columns: 1fr 1fr;
        padding: 16px 24px;
        background: var(--cream);
        border-bottom: 1px solid var(--sand);
      }

      .flight-table__col-label {
        font-size: 9px;
        font-weight: 500;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--gold-muted);
      }

      .flight-table__row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        padding: 14px 24px;
        border-bottom: 1px solid var(--sand);
      }

      .flight-table__row:last-child {
        border-bottom: none;
      }

      .flight-table__city {
        font-size: 14px;
        font-weight: 500;
        color: var(--deep-sea);
      }

      .flight-table__time {
        font-size: 14px;
        color: var(--slate);
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .flight-table__stops {
        font-size: 11px;
        color: var(--silver);
        padding: 2px 8px;
        background: var(--snow);
        border-radius: 2px;
      }

      .logistics-content {
        display: flex;
        flex-direction: column;
        gap: 28px;
      }

      .logistics-content__block {
      }

      .logistics-content__title {
        font-family: "Cormorant Garamond", serif;
        font-size: 24px;
        font-weight: 400;
        color: var(--deep-sea);
        margin-bottom: 12px;
      }

      .logistics-content__text {
