      <!-- ════════════════════════════════════════════════════════════════
       FAQ SECTION
       ════════════════════════════════════════════════════════════════ -->
      <section id="faq" class="section section--cream">
        <div class="section__inner">
          <div class="section-header">
            <span class="section-header__label">Questions</span>
            <h2 class="section-header__title">Raja Ampat FAQ</h2>
          </div>

          <!-- First 4 FAQs (always visible) -->
          <div class="faq-grid">
            <div class="faq-item">
              <h3 class="faq-item__question">
                What's the best time to visit Raja Ampat?
              </h3>
              <p class="faq-item__answer">
                October through April offers optimal conditions—calm seas,
                25-35m visibility, and peak manta activity. December-February is
                peak season. Avoid June-August.
              </p>
            </div>

            <div class="faq-item">
              <h3 class="faq-item__question">
                How much does a Raja Ampat charter cost?
              </h3>
              <p class="faq-item__answer">
                Luxury yacht charters range $55,000-$150,000+ per week. Budget
                approximately $8,000-15,000 per person all-inclusive.
              </p>
            </div>

            <div class="faq-item">
              <h3 class="faq-item__question">
                Is Raja Ampat good for non-divers?
              </h3>
              <p class="faq-item__answer">
                Absolutely. World-class snorkeling, manta encounters from the
                surface, kayaking, island hikes, bird watching, and village
                visits.
              </p>
            </div>

            <div class="faq-item">
              <h3 class="faq-item__question">
                How long should I spend in Raja Ampat?
              </h3>
              <p class="faq-item__answer">
                Minimum 7 nights to justify the travel; 10-14 nights ideal for
                comprehensive exploration.
              </p>
            </div>
          </div>

          <!-- Additional 4 FAQs (hidden by default) -->
          <div class="faq-grid faq-grid--hidden" id="faqMore">
            <div class="faq-item">
              <h3 class="faq-item__question">
                Is Raja Ampat safe for families?
              </h3>
              <p class="faq-item__answer">
                Yes, for families with children who snorkel confidently
                (typically age 8+). Calm anchorages and varied activities suit
                families well.
              </p>
            </div>

            <div class="faq-item">
              <h3 class="faq-item__question">
                What diving experience do I need?
              </h3>
              <p class="faq-item__answer">
                Open Water certification minimum, but 20-30+ logged dives
                recommended. Itineraries always include sites for all levels.
              </p>
            </div>

            <div class="faq-item">
              <h3 class="faq-item__question">Is there WiFi in Raja Ampat?</h3>
              <p class="faq-item__answer">
                Mobile coverage is minimal. Most yachts offer satellite WiFi
                (limited bandwidth—suitable for email, not streaming).
              </p>
            </div>

            <div class="faq-item">
              <h3 class="faq-item__question">
                What's the Raja Ampat Marine Park Permit?
              </h3>
              <p class="faq-item__answer">
                All visitors must purchase this permit (~$100 USD, valid one
                year). Revenue funds marine conservation. We arrange permits.
              </p>
            </div>
          </div>

          <div class="view-more-wrapper">
            <button
              class="link-toggle"
              id="viewMoreFaqBtn"
              onclick="toggleFaq()"
            >
              <span class="link-toggle__text">SHOW MORE FAQ</span>
              <svg class="link-toggle__arrow" viewBox="0 0 24 24"
                ><polyline points="6 9 12 15 18 9"></polyline></svg
              >
            </button>
          </div>
        </div>
      </section>

      <!-- ════════════════════════════════════════════════════════════════
       CTA BANNER
       ════════════════════════════════════════════════════════════════ -->
      <section class="cta-banner">
        <div class="cta-banner__inner">
          <h2 class="cta-banner__title">Ready to explore Raja Ampat?</h2>
          <p class="cta-banner__text">
