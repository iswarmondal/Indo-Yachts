        text-transform: uppercase;
        color: var(--white);
        margin-top: 16px;
        opacity: 0;
        transform: translateY(10px);
        transition: all 0.3s ease;
      }

      .dest-card:hover .dest-card__cta {
        opacity: 1;
        transform: translateY(0);
      }

      @media (max-width: 1100px) {
        .dest-grid {
          grid-template-columns: repeat(2, 1fr);
        }
