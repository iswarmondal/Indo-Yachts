          <button class="cta-banner__button" onclick="openModal()"
            >Plan Your Voyage <span>→</span></button
          >
        </div>
      </section>

      <!-- Modal Overlay -->
      <div class="modal-overlay" id="formModal" onclick="closeModal(event)">
        <div class="modal" data-lenis-prevent onclick="event.stopPropagation()">
          <button
            class="modal__close"
            onclick="closeModal()"
            aria-label="Close"
          >
            <svg
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
          <div class="modal__content" id="modalContent">
            <div class="modal__header">
              <p class="modal__eyebrow">Explore Raja Ampat</p>
              <h3 class="modal__headline">Plan Your Raja Ampat Charter</h3>
              <p class="modal__body">
                Share your dates and group size and we'll match you with the
                ideal yacht and itinerary for Raja Ampat.
              </p>
            </div>
            <form id="inquiryForm" onsubmit="handleSubmit(event)">
              <div class="form__row">
                <div class="form__field">
                  <input
                    type="text"
                    name="name"
                    placeholder="Your Name"
                    required
                  />
                </div>
                <div class="form__field">
                  <input type="tel" name="phone" placeholder="Phone Number" />
                </div>
              </div>
              <div class="form__field">
                <input
                  type="email"
                  name="email"
                  placeholder="Email Address"
                  required
                />
              </div>
              <div class="form__row">
                <div class="form__field">
                  <select name="guests" required>
                    <option value="" disabled selected>Group Size</option>
                    <option value="2-4">2–4 Guests</option>
                    <option value="5-8">5–8 Guests</option>
                    <option value="9-12">9–12 Guests</option>
                    <option value="13-16">13–16 Guests</option>
                    <option value="17+">17+ Guests</option>
                  </select>
                </div>
                <div class="form__field">
                  <select name="budget">
                    <option value="" disabled selected>Budget (Per Week)</option
                    >
                    <option value="under-50k">Under $50,000</option>
                    <option value="50k-80k">$50,000 – $80,000</option>
                    <option value="80k-120k">$80,000 – $120,000</option>
                    <option value="120k+">$120,000+</option>
                    <option value="flexible">Flexible</option>
                  </select>
                </div>
              </div>
              <div class="form__field">
                <textarea
                  name="details"
                  placeholder="Dates you're considering, destinations that interest you, or anything else that helps us personalize your recommendations."
                ></textarea>
              </div>
              <input
                type="hidden"
                name="source"
                value="destination-raja-ampat"
              />
              <input type="hidden" name="destination" value="Raja Ampat" />
              <button type="submit" class="form__submit"
                >Plan Your Voyage <span>→</span></button
              >
            </form>
          </div>
        </div>
      </div>
    </main>
    <script type="module">
      // Dive Sites Toggle
      function toggleDiveSites() {
        const moreSection = document.getElementById("diveSitesMore");
        const btn = document.getElementById("viewMoreBtn");

        if (moreSection.classList.contains("active")) {
          moreSection.classList.remove("active");
          btn.innerHTML =
            '<span class="link-toggle__text">VIEW MORE DIVE SITES</span><svg class="link-toggle__arrow" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"></polyline></svg>';
          btn.classList.remove("link-toggle--expanded");
        } else {
          moreSection.classList.add("active");
          btn.innerHTML =
            '<span class="link-toggle__text">VIEW LESS DIVE SITES</span><svg class="link-toggle__arrow" viewBox="0 0 24 24"><polyline points="6 15 12 9 18 15"></polyline></svg>';
          btn.classList.add("link-toggle--expanded");
        }
      }

      // FAQ Toggle
      function toggleFaq() {
        const moreSection = document.getElementById("faqMore");
        const btn = document.getElementById("viewMoreFaqBtn");

        if (moreSection.classList.contains("active")) {
          moreSection.classList.remove("active");
          btn.innerHTML =
            '<span class="link-toggle__text">SHOW MORE FAQ</span><svg class="link-toggle__arrow" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"></polyline></svg>';
          btn.classList.remove("link-toggle--expanded");
        } else {
          moreSection.classList.add("active");
          btn.innerHTML =
            '<span class="link-toggle__text">SHOW LESS FAQ</span><svg class="link-toggle__arrow" viewBox="0 0 24 24"><polyline points="6 15 12 9 18 15"></polyline></svg>';
          btn.classList.add("link-toggle--expanded");
        }
      }

      // Modal Functions
      function openModal() {
        document.getElementById("formModal").classList.add("active");
        document.body.style.overflow = "hidden";
        setTimeout(() => {
          const firstInput = document.querySelector(
            '.modal input[name="name"]'
          );
          if (firstInput) firstInput.focus();
        }, 400);
      }

      function closeModal(event) {
        if (event && event.target !== event.currentTarget) return;
        document.getElementById("formModal").classList.remove("active");
        document.body.style.overflow = "";
      }

      document.addEventListener("keydown", function (e) {
        if (e.key === "Escape") closeModal();
      });

      function handleSubmit(event) {
        event.preventDefault();
        document.getElementById("modalContent").innerHTML = `
        <div class="form-success">
          <svg class="form-success__icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <h3 class="form-success__title">Thank You</h3>
          <p class="form-success__text">We'll be in touch within 24 hours with personalized recommendations for your voyage.</p>
          <button class="form-success__close" onclick="closeModal()">Close</button>
        </div>
      `;
      }
    </script>
    <SmoothScroll luxury />
    <LuxuryInteractions />
  </body>
