---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import '../../styles/global.css';

const guides = (await getCollection('guides')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Guides — Indo Yachts"
			description="Expert guides to luxury yacht charters across Indonesia — from Raja Ampat expedition planning to seasonal sailing insights."
		/>
	</head>
	<body>
		<Header />

		<!-- Hero Section -->
		<section class="guides-hero">
			<div class="hero-inner">
				<span class="eyebrow">GUIDES</span>
				<h1>Charter Intelligence</h1>
				<p class="subtitle">
					Expert insights for planning your Indonesian yacht expedition — destinations,
					seasons, and the art of chartering well.
				</p>
			</div>
		</section>

		<!-- Guides Grid -->
		<section class="guides-grid-section">
			<div class="guides-grid">
				{
					guides.map((guide) => (
						<a href={`/guides/${guide.id}/`} class="guide-card">
							<div class="card-image">
								{guide.data.heroImage && (
									<Image
										width={720}
										height={480}
										src={guide.data.heroImage}
										alt={guide.data.title}
									/>
								)}
							</div>
							<div class="card-content">
								<span class="card-category">{guide.data.category}</span>
								<h2 class="card-title">{guide.data.title}</h2>
								<p class="card-description">{guide.data.description}</p>
								<span class="card-date">
									<FormattedDate date={guide.data.pubDate} />
								</span>
							</div>
						</a>
					))
				}
			</div>
		</section>

		<!-- CTA Banner -->
		<section class="cta-banner">
			<div class="cta-inner">
				<span class="cta-eyebrow">START YOUR JOURNEY</span>
				<h2 class="cta-headline">Ready to explore?</h2>
				<p class="cta-body">
					Our charter specialists can help match you with the right vessel, season, and
					itinerary for an unforgettable Indonesian voyage.
				</p>
				<a href="#contact" class="cta-button">
					Get Recommendations
					<span class="cta-arrow">&rarr;</span>
				</a>
			</div>
		</section>

		<Footer />

		<style>
			/* ===== Hero ===== */
			.guides-hero {
				background-color: var(--deep-sea);
				padding: var(--space-3xl) var(--space-md) var(--space-xl);
				text-align: center;
			}
			.hero-inner {
				max-width: 740px;
				margin: 0 auto;
			}
			.eyebrow {
				display: inline-block;
				font-family: var(--font-sans);
				font-size: var(--text-sm);
				font-weight: 600;
				letter-spacing: 0.2em;
				text-transform: uppercase;
				color: var(--gold-muted);
				margin-bottom: var(--space-sm);
			}
			.guides-hero h1 {
				font-family: var(--font-serif);
				font-weight: 300;
				font-size: 52px;
				line-height: 1.08;
				color: var(--iy-white);
				margin: 0 0 var(--space-md) 0;
			}
			.subtitle {
				font-family: var(--font-sans);
				font-weight: 400;
				font-size: var(--text-lg);
				line-height: 1.75;
				color: rgba(255, 255, 255, 0.7);
				max-width: 560px;
				margin: 0 auto;
			}

			/* ===== Grid Section ===== */
			.guides-grid-section {
				max-width: 1200px;
				margin: 0 auto;
				padding: var(--space-xl) var(--space-md);
			}
			.guides-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: var(--space-md);
			}

			/* ===== Card ===== */
			.guide-card {
				display: block;
				text-decoration: none;
				color: inherit;
				transition: transform 0.3s ease;
			}
			.guide-card:hover {
				color: inherit;
			}
			.card-image {
				overflow: hidden;
				aspect-ratio: 3 / 2;
			}
			.card-image img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
				border-radius: 0;
				transition: transform 0.4s ease;
			}
			.guide-card:hover .card-image img {
				transform: scale(1.05);
			}
			.card-content {
				padding: var(--space-sm) 0;
			}
			.card-category {
				display: inline-block;
				font-family: var(--font-sans);
				font-size: var(--text-xs);
				font-weight: 600;
				letter-spacing: 0.15em;
				text-transform: uppercase;
				color: var(--oxblood);
				margin-bottom: var(--space-xs);
			}
			.card-title {
				font-family: var(--font-serif);
				font-weight: 300;
				font-size: var(--text-xl);
				line-height: 1.2;
				color: var(--charcoal);
				margin: 0 0 var(--space-xs) 0;
				transition: color 0.3s ease;
			}
			.guide-card:hover .card-title {
				color: var(--oxblood);
			}
			.card-description {
				font-family: var(--font-sans);
				font-weight: 400;
				font-size: var(--text-base);
				line-height: 1.7;
				color: var(--slate);
				margin: 0 0 var(--space-xs) 0;
			}
			.card-date {
				font-family: var(--font-sans);
				font-size: var(--text-xs);
				font-weight: 400;
				color: var(--silver);
				letter-spacing: 0.05em;
			}

			/* ===== CTA Banner ===== */
			.cta-banner {
				background-color: var(--deep-sea);
				padding: var(--space-xl) var(--space-md);
				text-align: center;
			}
			.cta-inner {
				max-width: 620px;
				margin: 0 auto;
			}
			.cta-eyebrow {
				display: inline-block;
				font-family: var(--font-sans);
				font-size: var(--text-xs);
				font-weight: 600;
				letter-spacing: 0.2em;
				text-transform: uppercase;
				color: var(--gold-muted);
				margin-bottom: var(--space-sm);
			}
			.cta-headline {
				font-family: var(--font-serif);
				font-weight: 300;
				font-size: var(--text-3xl);
				line-height: 1.1;
				color: var(--iy-white);
				margin: 0 0 var(--space-sm) 0;
			}
			.cta-body {
				font-family: var(--font-sans);
				font-weight: 400;
				font-size: 15px;
				line-height: 1.75;
				color: rgba(255, 255, 255, 0.7);
				margin: 0 0 var(--space-md) 0;
			}
			.cta-button {
				display: inline-flex;
				align-items: center;
				gap: 8px;
				background-color: var(--oxblood);
				color: var(--iy-white);
				font-family: var(--font-sans);
				font-size: 12px;
				font-weight: 600;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				text-decoration: none;
				padding: 18px 36px;
				border: none;
				border-radius: 0;
				cursor: pointer;
				transition: background-color 0.3s ease;
			}
			.cta-button:hover {
				background-color: var(--oxblood-deep);
				color: var(--iy-white);
			}
			.cta-arrow {
				display: inline-block;
				transition: transform 0.3s ease;
			}
			.cta-button:hover .cta-arrow {
				transform: translateX(4px);
			}

			/* ===== Responsive ===== */
			@media (max-width: 1100px) {
				.guides-grid {
					grid-template-columns: repeat(2, 1fr);
				}
			}
			@media (max-width: 768px) {
				.guides-grid {
					grid-template-columns: 1fr;
				}
				.guides-hero h1 {
					font-size: 38px;
				}
				.guides-hero {
					padding: var(--space-xl) var(--space-sm) var(--space-lg);
				}
				.guides-grid-section {
					padding: var(--space-lg) var(--space-sm);
				}
				.cta-headline {
					font-size: var(--text-2xl);
				}
			}
			@media (max-width: 480px) {
				.guides-hero h1 {
					font-size: 32px;
				}
				.subtitle {
					font-size: var(--text-md);
				}
			}
		</style>
	</body>
</html>
