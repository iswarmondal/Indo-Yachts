          </div>
          
          <!-- Komodo -->
          <div class="panel__tab-content" id="dest-komodo">
            <div class="panel__featured-label">Komodo & Lesser Sundas</div>
            <a href="/destinations/komodo" class="panel__item">
              <div class="panel__item-name">Komodo National Park</div>
              <div class="panel__item-meta">Apr – Nov · Dragons, mantas, pink beaches</div>
            </a>
            <a href="/destinations/alor" class="panel__item">
              <div class="panel__item-name">Alor Archipelago</div>
              <div class="panel__item-meta">Apr – Nov · Traditional cultures, pristine reefs</div>
            </a>
            <a href="/destinations/bali-lombok" class="panel__item">
              <div class="panel__item-name">Bali & Lombok</div>
              <div class="panel__item-meta">Year-round · Gateway islands</div>
            </a>
            <a href="/destinations/moyo" class="panel__item">
              <div class="panel__item-name">Moyo Island</div>
              <div class="panel__item-meta">Apr – Nov · Secluded luxury</div>
            </a>
          </div>
          
          <!-- Surf -->
          <div class="panel__tab-content" id="dest-surf">
            <div class="panel__featured-label">The Endless Wave</div>
            <a href="/destinations/mentawai" class="panel__item">
              <div class="panel__item-name">Mentawai Islands</div>
              <div class="panel__item-meta">Apr – Oct · World's most consistent waves</div>
            </a>
            <a href="/destinations/telo" class="panel__item">
              <div class="panel__item-name">Telo Islands</div>
              <div class="panel__item-meta">Apr – Oct · Mentawai quality, uncrowded</div>
            </a>
            <a href="/destinations/sumba" class="panel__item">
              <div class="panel__item-name">Sumba</div>
              <div class="panel__item-meta">Apr – Oct · Empty lineups, raw power</div>
            </a>
            <a href="/destinations/rote-savu" class="panel__item">
              <div class="panel__item-name">Rote & Savu</div>
              <div class="panel__item-meta">Apr – Oct · Indonesia's southernmost waves</div>
            </a>
          </div>
          
          <!-- Sulawesi -->
          <div class="panel__tab-content" id="dest-sulawesi">
            <div class="panel__featured-label">Sulawesi</div>
            <a href="/destinations/bunaken-lembeh" class="panel__item">
              <div class="panel__item-name">Bunaken & Lembeh</div>
              <div class="panel__item-meta">Year-round · Wall diving meets macro magic</div>
            </a>
            <a href="/destinations/wakatobi" class="panel__item">
