              <div class="panel__item-meta">Oct – Apr · Crown jewel of marine biodiversity</div>
            </a>
            <a href="/destinations/cenderawasih-bay" class="panel__item">
              <div class="panel__item-name">Cenderawasih Bay</div>
              <div class="panel__item-meta">Year-round · Whale shark encounters</div>
